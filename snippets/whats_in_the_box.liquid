{% if product.metafields.custom.whats_in_box_image and product.metafields.custom.whats_in_box_context %}
  <div class="con in-the-box">
    <div class="container">
      <div class="in-the-box--wrapper">
        <div class="con-title">What's in the Box</div>
        <div class="con-context">
          {{ product.metafields.custom.whats_in_box_context | newline_to_br }}
        </div>
      </div>
      <div class="in-the-box-img">
        <img
          class="small--hide"
          src="{{ product.metafields.custom.whats_in_box_image | image_url }}"
          alt="what's in the box"
          width="400"
          height="400"
          loading="lazy"
        >
        <img
          class="pc--hide"
          src="{{ product.metafields.custom.whats_in_box_image_m | image_url }}"
          alt="what's in the box"
          width="400"
          height="400"
          loading="lazy"
        >
      </div>
    </div>
  </div>
  {% style %}
    @layer in-the-box {
      .con.in-the-box .container {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        grid-gap: 2em;
      }
      .con.in-the-box .container .pc--hide {
        display: none;
      }
      .con.in-the-box .container .small--hide {
        display: block;
      }
      .con.in-the-box .container .in-the-box--wrapper {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        text-align: left;
      }
      .con.in-the-box .container .in-the-box--wrapper .con-title {
        font-size: 2.8em;
        font-weight: 600;
        margin-bottom: 0.5em;
      }
      .con.in-the-box .container .in-the-box-img img {
        width: 100%;
        height: 100%;
        object-fit: contain;
      }
      @media screen and (max-width: 768px) {
        .con.in-the-box .container {
          grid-template-columns: 1fr;
          grid-gap: 0em;
        }
        .con.in-the-box .container .pc--hide {
          display: block;
        }
        .con.in-the-box .container .small--hide {
          display: none;
        }
      }
    }
  {% endstyle %}
{% endif %}
