{% comment %}
  drawer_position
  animation_row
  section
  search_enable
  link
  subnav_id
  child_list_handle
  mega_tag
{% endcomment %}
{% style %}
  #NavDrawer .collapsible-trigger__icon {
    height: 1em;
    width: 1em;
  }
  #NavDrawer .collapsible-trigger.is-open .collapsible-trigger__icon--open {
    transform: rotate(180deg) translateY(0%);
  }
  @media screen and (max-width: 1100px) {
    #NavDrawer.drawer--right {
      width: 100%;
    }
    .site-header__logo-link {
      margin: 0;
      padding-top: 0 !important;
    }
  }
  @media screen and (max-width: 768px) {
    .collapsible-trigger {
      padding: 0;
    }

    .mobile-nav__sublist .mobile-nav__link {
      text-align: left;
    }

    #NavDrawer .drawer__header {
      border-bottom: none;
    }
    #NavDrawer .site-header__search-form {
      border-bottom: 0.6px solid rgba(0, 0, 0, 0.1);
    }
    li.mobile-nav__item.mobile-nav__item--secondary {
      display: none;
    }
    li.mobile-nav__item .mobile-nav__child-item a.mobile-nav__link {
      position: relative;
    }
    a.sublink-more-link--wrapper {
      text-align: right;
      font-weight: 500;
      position: relative;
      right: 1rem;
    }
    a.Explore_links.sublink-more-link--wrapper::after {
      right: 0.4rem;
    }
    .mobile-nav__social li.mobile-nav__social-item {
      flex: 0 1 3.5rem;
      border: none;
    }
    .mobile-nav__social li.mobile-nav__social-item a {
      padding: 12px 0;
      width: 45px;
      height: 45px;
      display: grid;
      place-content: center;
      place-items: center;
      border: 2px solid #434547;
      border-radius: 50%;
      box-shadow: 18px 18px 30px rgb(0 0 0 / 10%), -18px -18px 30px rgb(255 255 255);
    }
    .mobile-nav__social li.mobile-nav__social-item a:hover {
      box-shadow: 0px 0px 0px rgb(0 0 0 / 20%), 0px 0px 0px rgb(255 255 255 / 80%),
        inset 18px 18px 30px rgb(0 0 0 / 10%), inset -18px -18px 30px rgb(255 255 255);
      transition: box-shadow 0.2s ease-out;
    }
  }
{% endstyle %}

<script>
  $(function () {
    $('.drawer-search-container #SearchClear').click(() => {
      $('.drawer-search-container input.site-header__search-input').val('');
    });
  });
</script>
{% style %}
  #{{ subnav_id }}-NavSubDrawer.drawer--{{ drawer_position }} {
    width: 100%;
    right: 0;
  }
  #{{ subnav_id }}-NavSubDrawer.drawer--{{ drawer_position }}.drawer--is-open {
    transform: translateX(0);
  }
  #{{ subnav_id }}-NavSubDrawer .drawer__fixed-header {
    padding-left: 1em !important;
    border-bottom: 0.6px solid rgba(0, 0, 0, 0.1);
  }
  #{{ subnav_id }}-NavSubDrawer .drawer__fixed-header .drawer__title {
    text-align: center;
    position: relative;
    font-size: 1.4em;
  }
  #{{ subnav_id }}-NavSubDrawer .drawer__fixed-header .drawer__title button {
    position: absolute;
    left: 0;
  }
  #{{ subnav_id }}-NavSubDrawer .drawer__scrollable {
    padding: 0;
    padding-top: 1em;
  }
  .mobile-nav__sublist > .mobile-nav__item {
    padding: 0.5em 0;
  }
  .mobile-nav__sublist > .mobile-nav__item .mobile-nav__child-item button,
  .mobile-nav__sublist > .mobile-nav__item .mobile-nav__child-item a {
    font-size: 1.4em;
  }
{% endstyle %}
<div id="{{ subnav_id }}-NavSubDrawer" class="drawer drawer--{{ drawer_position }}">
  <div class="drawer__contents">
    <div class="drawer__fixed-header">
      <div class="drawer__header appear-animation appear-delay-{{ animation_row }}">
        <div class="drawer__title">
          <button type="button" class="{{ subnav_id }}-drawer-button">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M19 12H5M5 12L12 19M5 12L12 5" stroke="#333333" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="icon__fallback-text">{{ 'general.drawers.close_menu' | t }}</span>
          </button>
          <span class="custom-txt-semibold">{{ link.title }}</span>
        </div>
      </div>
    </div>
    {% style %}
      #NavDrawer .drawer__fixed-header {
        padding-left: 0;
      }
      .drawer-search-container {
        display: flex;
        margin: 0.5rem;
        border-radius: 20px;
      }
      .drawer-search-container #SearchClear svg {
        background: #ccc;
        color: #fff;
        border-radius: 50%;
      }
      .drawer-search-container button.site-header__search-btn--submit {
        color: #000;
        border-radius: 0 20px 20px 0;
      }
      .collapsible-trigger.collapsible--auto-height .mobile-nav__faux-link::after {
        content: attr(data-tag);
        position: absolute;
        /* right: 0; */
        top: 0;
        transform: translate(-10%, 20%) scale(0.6);
        color: var(--colorLightLink);
        font-style: italic;
      }
      .mobile-nav__sublist .mobile-nav__item .mobile-nav__child-item {
        position: relative;
      }
      .mobile-nav__sublist .mobile-nav__item .mobile-nav__child-item .mobile-nav-product__link::before {
        content: attr(data-tag);
        position: absolute;
        right: 0;
        top: 0;
        color: var(--colorBtnPrimary);
        font-style: italic;
      }
    {% endstyle %}
    {%- if search_enable -%}
      <div class="drawer-search-container appear-animation appear-delay-{{ animation_row }}">
        <form
          action="{{ routes.search_url }}"
          method="get"
          role="search"
          id="HeaderSearchForm"
          class="site-header__search-form"
        >
          <input
            type="search"
            name="q"
            value="{{ search.terms | escape | replace: '*', '' }}"
            placeholder="{{ 'general.search.placeholder' | t }}"
            class="site-header__search-input"
            aria-label="{{ 'general.search.placeholder' | t }}"
          >
          <input type="hidden" name="type" value="{{ settings.search_type }}">
          <input type="hidden" name="options[prefix]" value="last">
          <button type="button" id="SearchClear" class="text-link site-header__search-btn">
            <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-close" viewBox="0 0 64 64">
              <path d="M19 17.61l27.12 27.13m0-27.12L19 44.74" />
            </svg>
            <span class="icon__fallback-text">{{ 'general.accessibility.close_modal' | t | json }}</span>
          </button>
          <button type="submit" class="text-link site-header__search-btn site-header__search-btn--submit">
            <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-search" viewBox="0 0 64 64">
              <path d="M47.16 28.58A18.58 18.58 0 1 1 28.58 10a18.58 18.58 0 0 1 18.58 18.58zM54 54L41.94 42" />
            </svg>
            <span class="icon__fallback-text">{{ 'general.search.submit' | t }}</span>
          </button>
        </form>
      </div>
    {%- endif -%}
    <div class="drawer__scrollable">
      <ul
        class="mobile-nav__sublist"
        role="navigation"
        aria-label="Primary"
      >
        {%- for childlink in link.links -%}
          {%- assign has_sub_dropdown = false -%}
          {%- assign grand_child_list_handle = childlink.url | handleize | append: forloop.index -%}

          {%- if childlink.links != blank -%}
            {%- assign has_sub_dropdown = true -%}
          {%- endif -%}

          {% assign strip_title = childlink.title | strip %}
          {%- if strip_title == 'New Arrival' -%}
            {%- assign has_sub_dropdown = true -%}
          {%- endif -%}
          <li class="mobile-nav__item">
            <div class="mobile-nav__child-item">
              {%- if has_sub_dropdown -%}
                <button
                  type="button"
                  aria-controls="Sublinklist-{{ child_list_handle }}-{{ grand_child_list_handle }}"
                  aria-labelledby="Sublabel-{{ grand_child_list_handle }}"
                  class="collapsible-trigger{% if childlink.active or childlink.child_active %} is-open{% endif %}"
                >
                  <span
                    class="mobile-nav__faux-link"
                    {% if link.active %}
                      data-active="true"
                    {% endif %}
                    data-tag="{{ mega_tag }}"
                  >
                    {{ childlink.title }}
                  </span>
                  <div class="mobile-nav__toggle">
                    <span class="faux-button">
                      {%- render 'collapsible-icons' -%}
                    </span>
                  </div>
                </button>
              {% else %}
                <a
                  href="{{ childlink.url }}"
                  class="notranslate mobile-nav__link {% if childlink.url contains '/products/' %}mobile-nav-product__link{% endif %} {% if childlink.url contains '/collections/' %}mobile-nav-collection__link{% endif %}"
                  id="Sublabel-{{ grand_child_list_handle }}"
                  {% if childlink.active %}
                    data-active="true"
                  {% endif %}
                  {% if childlink.url contains '/products/' %}
                    {%- assign subproduct_handle = childlink.url | remove: '/products/' -%}
                    {%- assign product = all_products[subproduct_handle] -%}
                    {% if product.tags contains 'New Arrivals' %}
                      data-tag="{{ mega_tag }}"
                    {% endif %}
                  {% endif %}
                >
                  {{ childlink.title | escape }}
                </a>
              {%- endif -%}
            </div>

            {%- if has_sub_dropdown -%}
              <div
                id="Sublinklist-{{ child_list_handle }}-{{ grand_child_list_handle }}"
                aria-labelledby="Sublabel-{{ grand_child_list_handle }}"
                class="mobile-nav__sublist collapsible-content collapsible-content--all{% if childlink.active or childlink.child_active %} is-open{% endif %}"
                {% if childlink.active or childlink.child_active %}
                  style="height: auto;"
                {% endif %}
              >
                <div class="collapsible-content__inner">
                  <ul class="mobile-nav__grandchildlist">
                    {% if childlink.title == 'New Arrival' %}
                      {% render 'new-arrival-nav-item',
                        childlink: childlink,
                        mega_tag: mega_tag,
                        add_class: 'new-arrival-product-item'
                      -%}
                    {% else %}
                      {%- for grandchildlink in childlink.links -%}
                        <li class="mobile-nav__item">
                          <a
                            href="{{ grandchildlink.url }}"
                            class="mobile-nav__link {% if grandchildlink.url contains '/collections/' %} mobile-nav__link--collection {% endif %}"
                            {% if grandchildlink.active %}
                              data-active="true"
                            {% endif %}
                            {% if grandchildlink.url contains '/products/' %}
                              {%- assign subproduct_handle = grandchildlink.url | remove: '/products/' -%}
                              {%- assign product = all_products[subproduct_handle] -%}
                              {% if product.tags contains 'New Arrivals' %}
                                data-tag="{{ mega_tag }}"
                              {% endif %}
                            {% endif %}
                            {% if grandchildlink.url contains '/collections/'
                              and grandchildlink.url contains 'filter'
                            %}
                              rel="nofollow"
                            {% endif %}
                          >
                            {% render 'grandchild-nav-item',
                              grandchildlink: grandchildlink,
                              link: link,
                              childlink: childlink,
                              section: section
                            -%}
                          </a>
                        </li>
                      {%- endfor -%}
                    {% endif %}
                  </ul>
                </div>
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof theme === 'undefined' || typeof theme.Drawers !== 'function') {
      return;
    }

    (function () {
      const subnavId = '{{ subnav_id }}'; 
      const drawerId = subnavId + '-NavSubDrawer';
      const drawerName = subnavId;

      const drawerInstance = new theme.Drawers(drawerId, drawerName);
      const backBtn = drawerInstance.drawer.querySelector(`.${subnavId}-drawer-button`);

      if (backBtn) {
        backBtn.addEventListener('click', function (evt) {
          evt.preventDefault();
          evt.stopPropagation();
          
          drawerInstance.back();
        });
      }
    })();
  });
</script>
