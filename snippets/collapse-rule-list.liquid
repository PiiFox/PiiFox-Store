<script>
  document.addEventListener('DOMContentLoaded', function () {
    const items = document.querySelectorAll('.product-block-collapse-rule-list .product-rule-item .product-rule-item-header');

    items.forEach(function (item) {
      item.addEventListener('click', function (e) {
        const targetItem = e.target.closest('.product-rule-item');
        const allRules = document.querySelectorAll(`.product-block-collapse-rule-list .product-rule-item`);

        if(window.innerWidth <= 768) {
          allRules.forEach((rule) => rule.classList.remove('active'));
          targetItem.classList.add('active');
          return;
        }

        const tabIndex = targetItem.dataset.tab;
        const popupId = 'ProductRuleList-popup';
        document.querySelector(`.${popupId}`).style.display = 'block';

        // 获取当前点击项内的 body 元素
        const activeBody = document.querySelector(`#${popupId} .product-rule-item[data-index="${tabIndex}"]`);

        // 移除所有 .product-rule-item-body 的 active 类
        const allBodies = document.querySelectorAll(`#${popupId} .product-rule-item`);
        allBodies.forEach((body) => body.classList.remove('active'));

        // 给当前点击项内的 body 添加 active 类
        if (activeBody) {
          activeBody.classList.add('active');
        }
      });
    });
  });
</script>
