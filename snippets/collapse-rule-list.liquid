<script>
  document.addEventListener('DOMContentLoaded', function () {
    const popupId = 'ProductRuleList-popup';
    const cancelBtn = document.querySelector(`#${popupId} .popup-close-btn`);
    if (cancelBtn) {
      cancelBtn.addEventListener('click', function () {
        document.querySelector(`.${popupId}`).style.display = 'none';
      });
    }

    const maskArea = document.querySelector(`.ProductRuleList-popup-mask`);
    if (maskArea) {
      maskArea.addEventListener('click', function () {
        document.querySelector(`.${popupId}`).style.display = 'none';
      });
    }

    const items = document.querySelectorAll(`#${popupId} .product-rule-item .product-rule-item-header`);
    items.forEach((item) => {
      item.addEventListener('click', function (e) {
        e.stopPropagation();
        const activeBody = e.target.closest('.product-rule-item');

        const allBodies = document.querySelectorAll(`#${popupId} .product-rule-item`);
        allBodies.forEach((body) => body.classList.remove('active'));

        if (activeBody) {
          activeBody.classList.add('active');
        }
      });
    });
  });
</script>
{% style %}
  .ProductRuleList-popup {
    display: none;
    position: relative;
    z-index: 1099;
  }
  .ProductRuleList-popup-mask {
    position: fixed;
    width: 100vw;
    height: 100vh;
    left: 0;
    top: 0;
    overflow: hidden;
    z-index: 100;
    display: grid;
    place-items: center;
  }
  #ProductRuleList-popup {
    padding: 2em 3em;
    position: relative;
    z-index: 101;
    max-width: 700px;
    background: #fff;
    box-shadow: 0 0 8px #ddd;
  }
  #ProductRuleList-popup .popup-header {
    padding-bottom: 2em;
    display: flex;
    justify-content: space-between;
  }
  #ProductRuleList-popup .popup-close-btn {
  }
  #ProductRuleList-popup .popup-title {
    text-align: left;
    font-size: 2em;
    font-weight: 700;
  }
  .product-rule-list--wrapper .product-rule-item {
    padding: 1em;
    border-bottom: 1px solid var(--colorBorder);
    cursor: pointer;
  }
  .product-rule-list--wrapper .product-rule-item-header {
    display: flex;
    align-items: center;
  }
  .product-rule-list--wrapper .product-rule-item .collapse-rule-item-icon img {
    width: 1.3em;
    margin-right: 1em;
  }
  .product-rule-list--wrapper .product-rule-item .collapse-rule-item-title {
    font-size: 1.1em;
    font-weight: 600;
    font-family: 'PF_Semibold', 'Manrope', sans-serif;
    letter-spacing: 0.1em;
    flex: 1;
    text-align: left;
  }
  .product-rule-list--wrapper .product-rule-item .collapse-rule-item-collapse {
    font-size: 1.3em;
    color: #bfbfc3;
    margin-left: 1em;
  }
  .product-rule-list--wrapper .product-rule-item .product-rule-item-body {
    height: 0;
    opacity: 0;
    font-size: 1.1em;
    font-weight: 400;
    font-family: 'PF_Light', 'Manrope', sans-serif;
    color: var(--color-second-text);
    text-align: left;
    padding-top: 0.5em;
    overflow: hidden; 
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94); 
  }
  .product-rule-list--wrapper .product-rule-item .product-rule-item-body b {
    color: #000;
  }
  .product-rule-list--wrapper .product-rule-item .product-rule-item-body a {
    text-decoration: underline;
    pointer-events: auto;
  }
  .product-rule-list--wrapper .product-rule-item.active .product-rule-item-body {
    height: auto;
    opacity: 1;
  }
  @media screen and (max-width: 768px) {
    .ProductRuleList-popup-mask {
      place-items: flex-end;
    }
    #ProductRuleList-popup {
      max-width: 100%;
    }
  }
{% endstyle %}

