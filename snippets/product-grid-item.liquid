{% comment %}
  Arguments
  - product: product object
  - [per_row]: number of items per row
  - [quick_shop_enable]: boolean
  - [collection]: collection object,
  short_introduction_enable: short_introduction_enable,
  short_point_desc_enable: short_point_desc_enable,
  product_card_btn_label: product_card_btn_label
{% endcomment %}

{%- liquid
  unless per_row
    assign per_row = 4
  endunless

  case per_row
    when 1
      assign grid_item_width = ''
    when 2
      assign grid_item_width = 'medium-up--one-half'
    when 3
      assign grid_item_width = 'small--one-half medium-up--one-third'
    when 4
      assign grid_item_width = 'small--one-half medium-up--one-quarter'
    when 5
      assign grid_item_width = 'small--one-half medium-up--one-fifth'
    when 6
      assign grid_item_width = 'small--one-half medium-up--one-sixth'
  endcase

  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif

  assign product_tags = product.tags | join: ','
  assign has_custom_label = false
  assign has_new_label = false
  if product.metafields.theme.label and product.metafields.theme.label != blank
    assign has_custom_label = true
    assign custom_label = product.metafields.theme.label.value
  else
    for tag in product.tags
      if tag contains 'OFF'
        assign has_custom_label = true
        assign custom_label = tag
      elsif tag contains 'New'
        assign has_new_label = true
      endif
    endfor
  endif
-%}

<div
  class="grid__item grid-product grid-product--{{ product.id }} {{ grid_item_width }}{% if quick_shop_enable %} grid-product__has-quick-shop{% endif %}"
  data-aos="row-of-{{ per_row }}"
  data-product-handle="{{ product.handle }}"
  data-product-id="{{ product.id }}"
  data-AVAILABILITY="{% if product.available %}1{% else %}0{% endif %}"
  data-PRICE="{{ product.price | money_without_currency }}"
  data-CUSTOM-FILTERS="{{ product.metafields.custom.filters | metafield_text }}"
>
  <div class="grid-product__content">
    {%- if has_new_label -%}
      <div class="grid-product__tag grid-product__tag--sale">
        {{ 'products.product.new' | t }}
      </div>
    {%- elsif product.available != true -%}
      <div class="grid-product__tag grid-product__tag--sold-out">
        {{ 'products.product.sold_out' | t }}
      </div>
    {%- endif -%}
    {%- if has_custom_label -%}
      <div class="grid-product__tag grid-product__tag--custom">
        {{ custom_label }}
      </div>
    {%- endif -%}

    {%- liquid
      assign fixed_aspect_ratio = false
      unless settings.product_grid_image_size == 'natural'
        assign fixed_aspect_ratio = true
      endunless

      assign preview_image = product.featured_media.preview_image
      assign img_url = preview_image | img_url: '1x1' | replace: '_1x1.', '_{width}x.'
    -%}

    <a href="{{ product.url }}" class="grid-product__link">
      {% if short_point_desc_enable and product.metafields.custom.short_point_desc != blank %}
        <div class="content-toggle-btn">
          <img class="open-content-icon" src="{{ 'eye.png' | asset_url }}" alt="open content" width="24" height="24">
          <img
            class="close-content-icon"
            src="{{ 'close.svg' | asset_url }}"
            alt="close content"
            width="24"
            height="24"
          >
        </div>
        <div class="grid-product-item-content">
            <div class="custom-short_point_desc">
              {% render 'product-short-point-desc', product: product %}
            </div>
        </div>
      {% endif %}

      <div class="grid-product__image-mask">
        {%- if quick_shop_enable -%}
          <div class="quick-product__btn quick-product__btn--not-ready js-modal-open-quick-modal-{{ product.id }} small--hide">
            <span class="quick-product__label">{{ settings.quick_shop_text }}</span>
          </div>
        {%- endif -%}

        {%- if fixed_aspect_ratio -%}
          <div
            class="grid__image-ratio grid__image-ratio--{{ settings.product_grid_image_size }}"
          >
            <img
              class="lazyload{% unless settings.product_grid_image_fill %} grid__image-contain{% endunless %}"
              data-src="{{ img_url }}"
              data-widths="[360, 540, 720, 900, 1080]"
              data-aspectratio="{{ preview_image.aspect_ratio }}"
              data-sizes="auto"
              alt="{{ preview_image.alt | escape }}"
            >
          </div>
        {%- else -%}
          <div
            class="image-wrap"
            style="height: 0; padding-bottom: {{ 100 | divided_by: 1 }}%;"
          >
            <img
              class="grid-product__image lazyload"
              data-src="{{ img_url }}"
              data-widths="[360, 540, 720, 900, 1080]"
              data-aspectratio="{{ preview_image.aspect_ratio }}"
              data-sizes="auto"
              alt="{{ preview_image.alt | escape }}"
            >
            <noscript>
              <img
                class="grid-product__image lazyloaded"
                src="{{ preview_image | img_url: '400x' }}"
                alt="{{ preview_image.alt | escape }}"
              >
            </noscript>
          </div>
        {%- endif -%}

        {%- if settings.product_hover_image and product.media.size > 1 -%}
          {%- for media in product.media offset: 1 limit: 1 -%}
            {%- assign second_image = media.preview_image -%}
          {%- endfor -%}
          <div class="grid-product__secondary-image small--hide">
            {%- assign img_url = second_image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
            <img
              class="lazyload"
              data-src="{{ img_url }}"
              data-widths="[360, 540, 720, 1000]"
              data-aspectratio="{{ second_image.aspect_ratio }}"
              data-sizes="auto"
              alt="{{ second_image.alt }}"
            >
          </div>
        {%- endif -%}

        {%- if settings.enable_swatches -%}
          {%- assign swatch_trigger = 'products.general.color_swatch_trigger' | t | downcase -%}
          {%- for option in product.options_with_values -%}
            {%- liquid
              assign option_name = option.name | downcase
              assign is_color = false
              if option_name contains swatch_trigger
                assign is_color = true
              elsif swatch_trigger == 'color' and option_name contains 'colour'
                assign is_color = true
              endif
            -%}
            {%- if is_color -%}
              {%- assign option_index = forloop.index0 -%}
              {%- assign values = '' -%}
              {%- for variant in product.variants -%}
                {%- assign value = variant.options[option_index] %}
                {%- unless values contains value -%}
                  {%- liquid
                    assign values = values | join: ',' | append: ',' | append: value | split: ','
                  -%}

                  {%- if variant.image -%}
                    <div
                      class="grid-product__color-image grid-product__color-image--{{ variant.id }} small--hide"
                    ></div>
                  {%- endif -%}
                {%- endunless -%}
              {%- endfor -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
      {%- if settings.enable_swatches -%}
        {%- liquid
          assign swatch_trigger = 'products.general.color_swatch_trigger' | t | downcase
          assign swatch_file_extension = 'png'
          assign color_count = 0
        -%}

        {%- for option in product.options_with_values -%}
          {%- liquid
            assign option_name = option.name | downcase
            assign is_color = false
            if option_name contains swatch_trigger
              assign is_color = true
            elsif swatch_trigger == 'color' and option_name contains 'colour'
              assign is_color = true
            endif
          -%}
          {%- if is_color -%}
            {%- assign option_index = forloop.index0 -%}
            {%- assign values = '' -%}
            <div class="grid-product__colors grid-product__colors--{{ product.id }}">
              {%- for variant in product.variants -%}
                {%- assign value = variant.options[option_index] %}
                {%- unless values contains value -%}
                  {%- liquid
                    assign values = values | join: ',' | append: ',' | append: value | split: ','

                    assign color_file_name = value | handle | append: '.' | append: swatch_file_extension
                    assign color_image = color_file_name | file_img_url: '50x50' | prepend: 'https:' | split: '?' | first
                    assign color_swatch_fallback = value | split: ' ' | last | handle
                    assign color_count = color_count | plus: 1
                  -%}

                  <a
                    href="{{ variant.url | within: collection }}"
                    class="color-swatch color-swatch--small color-swatch--{{ value | handle }}{% if variant.image %} color-swatch--with-image{% endif %}"
                    {% if variant.image %}
                      data-variant-id="{{ variant.id }}"
                      data-variant-image="{{ variant.image | img_url: '400x' }}"
                    {% endif %}
                    aria-label="{{ product.title }} - {{ value }}"
                    style="background-color: {{ color_swatch_fallback }};background-image: url({{ color_image }});"
                  >
                    <span class="visually-hidden">{{ value }}</span>
                  </a>
                {%- endunless -%}
              {%- endfor -%}
            </div>
            {%- if color_count < 2 -%}
              {%- style -%}
                .grid-product__colors--{{ product.id }} {
                  display: none;
                }
              {%- endstyle -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </a>
    <div class="grid-product__meta">
      <div class="grid-product__title grid-product__title--{{ settings.type_product_style }} custom-txt-semibold notranslate">
        {{ product.title }}
      </div>
      {%- if settings.vendor_enable -%}
        <div class="grid-product__vendor">{{ product.vendor }}</div>
      {%- endif -%}

      <div class="grid-product__price">
        {%- if on_sale -%}
          <span class="visually-hidden">{{ 'products.general.sale_price' | t }}</span>
        {% endif %}
        {%- if product.price_varies -%}
          {%- assign price = product.price_min | money -%}
          {{ 'products.general.from_text_html' | t: price: price }}
        {%- else -%}
          {{ product.price | money }}
        {%- endif -%}

        {%- if on_sale -%}
          <span class="visually-hidden">{{ 'products.general.regular_price' | t }}</span>
          <span class="grid-product__price--original">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
        
        {%- if on_sale -%}
          {%- if settings.product_save_amount -%}
            {%- if settings.product_save_type == 'dollar' -%}
              {%- capture saved_amount -%}{{ product.compare_at_price | minus: product.price | money }}{%- endcapture -%}
            {%- else -%}
              {%- capture saved_amount -%}{{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}%{%- endcapture -%}
            {%- endif -%}
            <span class="grid-product__price--savings">
              {{ 'products.general.save_html' | t: saved_amount: saved_amount }}
            </span>
          {%- endif -%}
        {%- endif -%}

        {%- assign product_variant = product.selected_or_first_available_variant -%}
        {%- if product_variant.unit_price_measurement -%}
          <div class="product__unit-price">
            {%- capture unit_price_base_unit -%}
                {%- if product_variant.unit_price_measurement -%}
                  {%- if product_variant.unit_price_measurement.reference_value != 1 -%}
                    {{ product_variant.unit_price_measurement.reference_value }}
                  {%- endif -%}
                  {{ product_variant.unit_price_measurement.reference_unit }}
                {%- endif -%}
              {%- endcapture -%}

            {{ product_variant.unit_price | money }}/{{ unit_price_base_unit }}
          </div>
        {%- endif -%}
      </div>
      <div class="bottom_btn">
        <a href="{{ product.url }}" class="lm_btn">
          <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-cart" viewBox="0 0 64 64">
            <path fill="none" d="M14 17.44h46.79l-7.94 25.61H20.96l-9.65-35.1H3"></path><circle cx="27" cy="53" r="2"></circle><circle cx="47" cy="53" r="2"></circle>
          </svg>
          {% if product_card_btn_label %}
            {{ product_card_btn_label }}
          {% else %}
            {{ 'general.custom.shop_now' | t }}
          {% endif %}
        </a>
      </div>
    </div>
  </div>

  {%- if settings.enable_product_reviews -%}
    <span class="shopify-product-reviews-badge" data-id="{{ product.id }}"></span>
  {%- endif -%}

  {%- if quick_shop_enable -%}
    {%- render 'quick-shop-modal', product: product -%}
  {%- endif -%}
</div>
<script>
  $(window).on('load', function () {
    $(document).on('click', '.grid-product--{{ product.id }} .content-toggle-btn', function (e) {
      e.stopPropagation();
      e.preventDefault();
      $(this).toggleClass('active');
      $(this).siblings('.grid-product-item-content').toggleClass('active');
    });
  });
</script>
{% style %}
  .grid-product__tag {
    top: 0;
    left: 0;
    right: unset;
    background: url('{{ 'discount.svg' | asset_url }}') center center / 100% 100% no-repeat ;
    aspect-ratio: 28/27;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    text-align: center;
    font-weight: 600;
    letter-spacing: 0.1em;
    max-width: 4em;
    line-height: 1.4;
    padding: 0.1em 0.5em 0.7em 0.5em ;
    z-index: 1;
  }
  .grid-product__tag.grid-product__tag--sold-out {
    background: url('{{ 'sale_out.svg' | asset_url }}') center center / 100% 100% no-repeat ;
    letter-spacing: 0em;
  }
  [data-center-text=true] .grid__item.grid-product .grid-product__colors {
    position: absolute;
    transform: translate(10%, -130%);
    z-index: 1;
  }
  .grid__item.grid-product {
    padding: 0.5em;
  }
  .grid__item.grid-product .grid-product__content {
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 0.4em;
  }
  .grid__item.grid-product .grid-product__content {}
  .grid__item.grid-product .grid-product__link {
    position: relative;
  }
  .grid__item.grid-product .content-toggle-btn {
    position: absolute;
    top: 5%;
    right: 5%;
    z-index: 4;
    color: #000;
  }
  .grid__item.grid-product .content-toggle-btn img {
    width: 1.5em;
    height: 1.5em;
    display: none;
  }
  .grid__item.grid-product .content-toggle-btn .open-content-icon {
    display: block;
  }
  .grid__item.grid-product .content-toggle-btn.active .open-content-icon {
    display: none;
  }
  .grid__item.grid-product .content-toggle-btn.active .close-content-icon {
    display: block;
  }
  .grid__item.grid-product .grid-product-item-content {
    position: absolute;
    width: 100%;
    height: 100%;
    padding: 1em;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    text-align: left;
    overflow: hidden;
    text-overflow: ellipsis;
    display: none;
    z-index: 3;
    background: rgba(255, 255, 255, 0.7);
  }
  .grid__item.grid-product .grid-product-item-content.active {
    display: flex;
  }
  .grid__item.grid-product .grid-product__link:hover .grid-product__image-mask {
    padding: 0;
  }
  .grid__item.grid-product .grid-product__meta {
    padding: 1em ;
    text-align: left;
    color: rgb(29 29 31);
    position: relative;
    overflow: hidden;
  }
  .grid__item.grid-product .grid-product__meta .grid-product__price {
    text-align: left;
    padding: 0.7em 0 0.2em 0;
    margin-bottom: 1em;
  }
  .grid__item.grid-product .grid-product__meta .bottom_btn {}
  .grid__item.grid-product .bottom_btn a {
    background: #fff;
    color: var(--colorThemePrimary);
    border: 1px solid var(--colorThemePrimary);
    border-radius: 0.4em;
    width: 100%;
    text-align: center;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 1em;
    font-weight: 300;
    letter-spacing: 0.1em;
  }
  .grid__item.grid-product .bottom_btn a.lm_btn svg {
    width: 1.2em;
    height: 1.2em;
    margin-right: 1em;
  }
  .grid__item.grid-product .bottom_btn a.lm_btn {
    background: var(--colorThemePrimary);
    color: #fff;
    border: 1px solid var(--colorThemePrimary);
    padding: 0.7em 0;
  }
  .grid__item.grid-product .bottom_btn a.lm_btn:hover {
    background: #f1f6ee;
    color: var(--colorThemePrimary);
  }

  .grid-product__price > span.money {
    color: var(--colorThemePrimary);
    font-weight: 500;
    font-size: 1.2em;
  }
  ul.short-descrbe-list--wrapper {
    font-size: 0.8rem;
    margin: 0 0 0.5rem 1rem;
    text-align: left;
  }
  
  .grid-product__title.grid-product__title--body {
    font-weight: 600;
    -webkit-line-clamp: 2;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1em;
    font-size: 1.2em;
    height: 2.4em;
    word-wrap: break-word; 
    word-break: keep-all;  
    white-space: normal;   
  }
  .grid-product .grid-product__content > .grid-product__link img {
    aspect-ratio: 1 / 1;
    object-fit: contain;
  }
  
  @media screen and (max-width: 768px) {
    .grid__item.grid__item--content {
      padding-left: 0;
    }
    .collection-grid__wrapper > .grid--uniform.small--grid--flush {
      padding-left: 1em;
    }
    .grid__item.grid-product {
      box-sizing: border-box;
    }
    .grid__item.grid-product .grid-product__meta {}
    .grid__item.grid-product .grid-product__meta .bottom_btn {
      left: unset;
      right: 0;
      bottom: 0;
    }
    .grid-product__title.grid-product__title--body {
      height: unset;
    }
  }
  @media screen and (max-width: 500px) {
    .grid__item.grid-product.small--one-halfs .bottom_btn a {
      flex-wrap: nowrap;
      white-space: nowrap;
    }
    .grid__item.grid-product.small--one-halfs .bottom_btn a svg {
      display: none;
    }
  }
{% endstyle %}
