    font-size: 1em;
    color: var(--colorText);
    line-height: 1.2;
}
.newsletter__input-group-checkbox span p {
    margin: 0;
}
.newsletter__input-group-checkbox span a {
    color: var(--colorLightLink);
    margin: 0 0.2em;
    border-bottom: 1px solid currentColor;
}
