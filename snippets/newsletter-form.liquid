.foot-news .newsletter__input-group {
    background: rgba(0, 0, 0, 0.5);
}
.foot-news .newsletter__input-group input[type=email], 
.foot-news .newsletter__input-group button[type=submit] {
    color: #fff;
    border: none;
    font-size: 1em;
}
.foot-news .newsletter__input-group input[type=email] {
    padding-left: 1.5em;
    background: transparent;
}
.foot-news .newsletter__input-group .input-group-btn button[type=submit] {
    border-radius: 20em;
    padding: 0.7em 1.4em;
    background: var(--colorThemePrimary);
