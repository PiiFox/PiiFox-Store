<style>
  @layer con-switches-spec {
    .con.con-switches-spec .container.page-width {
      overflow: hidden;
    }
    .con.con-switches-spec .container .con-title {
      font-size: 2.8em;
      text-align: center;
    }
    .con.con-switches-spec .con-switches-spec-content {
      width: 100%;
      max-width: 100%;
      overflow-x: auto;
      scroll-behavior: auto;
      display: inline-block;
      scrollbar-width: none; /* Firefox */
      -ms-overflow-style: none; /* IE/Edge */
      cursor: grab;
      border-spacing: 0px !important;
    }
    .con.con-switches-spec .con-switches-spec-content:active {
      cursor: grabbing;
    }
    .con.con-switches-spec .grid-col-title,
    .con.con-switches-spec .grid-cell.switch-name {
      font-weight: 600;
    }
    .con.con-switches-spec .con-switches-spec-content::-webkit-scrollbar {
      display: none;
    }
    .con.con-switches-spec .grid-col-switches .grid-cell,
    .con.con-switches-spec .grid-col-title .grid-cell {
      padding: 0.5em 1em;
      text-align: center;
      white-space: nowrap;
      user-select: none;
    }
    .con.con-switches-spec .grid-col-title .grid-cell {
      padding: 1em;
    }
    .con.con-switches-spec .grid-col-switches .grid-cell.grid-cell--1,
    .con.con-switches-spec .grid-col-title .grid-cell.grid-cell--1 {
      position: sticky;
      left: 0;
      z-index: 9;
    }
    .con.con-switches-spec .grid-col-switches .grid-cell span,
    .con.con-switches-spec .grid-col-title .grid-cell span {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .con.con-switches-spec td.grid-cell {
      background: #fff !important;
      border-bottom: 1px solid #f5f5f5 !important;
    }
    .con.con-switches-spec td.grid-cell.dark-cell {
      background: #f5f5f5 !important;
    }
    .con.con-switches-spec .grid-cell .switch-img {
      height: unset;
      width: 5em;
      min-width: 5em;
      object-fit: contain;
    }
    .con-switches-spec--table {
      position: relative;
    }
    .con-switches-spec--table .drag-right {
      position: absolute;
      height: 3em;
      width: auto;
      top: 50%;
      right: 0;
      z-index: 9;
      transform: translateY(-50%);
      cursor: none;
      user-select: none;
      pointer-events: none;
    }
    .con-switches-spec--table .drag-right img {
      height: 100%;
      width: auto;
    }
    @media screen and (max-width: 1200px) {
    }
    @media screen and (max-width: 768px) {
      .con.con-switches-spec {
        font-size: 0.8em;
      }
    }
  }
</style>
<div class="con con-switches-spec">
  <div class="container">
    <div class="con-switches-spec--wrapper">
      <div class="con-title">Switch Specifications</div>
      <div class="con-context"></div>
    </div>
    {% assign switches_compare = product.metafields.custom.switches_compare.value %}
    {% assign first_switch = switches_compare | first %}
    <div class="con-switches-spec--table">
      <div class="drag-right">
        {{ 'right-arrow.svg' | asset_url | img_tag: 'draw to right', 'right-arrow-icon' }}
      </div>
    {% if first_switch.system.type == 'mechanical_switch' %}
