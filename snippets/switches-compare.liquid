              </td>
              <td
                class="grid-cell grid-cell-7 dark-cell"
                data-label="Total Travel"
              >
                Total Travel
              </td>
              <td class="grid-cell grid-cell-8" data-label="Sound Level">Sound Level</td>
              <td
                class="grid-cell grid-cell-9 dark-cell"
                data-label="Factory Lubed"
              >
                Factory Lubed
              </td>
              <td
                class="grid-cell grid-cell-10"
                data-label="Pins"
              >
                Pins
              </td>
              <td
                class="grid-cell grid-cell-11 dark-cell"
                data-label="Stem Material"
              >
                Stem Material
              </td>
              <td
                class="grid-cell grid-cell-12"
                data-label="Top Housing Material"
              >
                Top Housing Material
              </td>
              <td
                class="grid-cell grid-cell-13 dark-cell"
                data-label="Bottom Housing Material"
              >
                Bottom Housing Material
              </td>
              <td
                class="grid-cell grid-cell-14"
                data-label="Spring"
              >
                Spring
              </td>
              <td
                class="grid-cell grid-cell-15 dark-cell"
                data-label="Light Support"
              >
                Light Support
              </td>
              <td
                class="grid-cell grid-cell-16"
                data-label="Operation Life"
              >
                Operation Life
              </td>
            </tr>
          </thead>
          <tbody>
            {% for switch in switches_compare %}
