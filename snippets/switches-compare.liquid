                      height="400"
                      loading="lazy"
                    >
                  {% endif %}
                </td>
                <td class="grid-cell grid-cell-0">
                  <span>{{ switch.switch_name }}</span>
                </td>
                <td class="grid-cell grid-cell-1 dark-cell">
                  <span>{{ switch.brand.value.label }}</span>
                </td>
                <td class="grid-cell grid-cell-2">
