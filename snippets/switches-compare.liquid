<script>
  (function () {
    const wrap = document.querySelector('.con.con-switches-spec .con-switches-spec-content');
    let isDrag = false;
    let startX = 0;
    let scrollLeft = 0;

    wrap.addEventListener('mousedown', (e) => {
      isDrag = true;
      startX = e.pageX - wrap.offsetLeft;
      scrollLeft = wrap.scrollLeft;
      wrap.style.cursor = 'grabbing';
    });

    wrap.addEventListener('mousemove', (e) => {
      if (!isDrag) return;
      e.preventDefault(); // 防止选中文本、默认行为
      const x = e.pageX - wrap.offsetLeft;
      const move = x - startX;
      wrap.scrollLeft = scrollLeft - move;
    });

    ['mouseup', 'mouseleave'].forEach((evt) => {
      wrap.addEventListener(evt, () => {
        isDrag = false;
        wrap.style.cursor = 'grab';
      });
    });
  })();
</script>
