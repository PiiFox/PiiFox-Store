<div class="feedback-list-section-{{ section.id }}">
  <div class="feedback-list-section--wrapper page-width wow bounceInUp">
    <h2 class="feedback-list-section-title custom-txt-bold appear-delay{% cycle '','-1','-2','-3','-4' %}">
      {{ section.settings.feedback_list_title }}
    </h2>
    <h3 class="feedback-list-section-subtitle custom-txt-semibold appear-delay{% cycle '','-1','-2','-3','-4' %}">
      {{ section.settings.feedback_list_subtitle }}
    </h3>
    <p class="feedback-list-section-context custom-txt-light appear-delay{% cycle '','-1','-2','-3','-4' %}">
      {{ section.settings.feedback_list_context }}
    </p>
    <div class="feedback-list-section-content swiper-container">
      <div class="feedback-list-list swiper-wrapper">
        {% for block in section.blocks %}
          <div class="feedback-list-item swiper-slide">
            <div class="feedback-list-item-image">
              {% if block.settings.series != blank %}
                <div class="feedback-list-item-tag">
                  {% if block.settings.icon != blank %}
                    <img
                      src="{{ block.settings.icon | image_url }}"
                      width="{{ block.settings.icon.width }}"
                      height="{{ block.settings.icon.height }}"
                      loading="lazy"
                      alt="{{ block.settings.icon.alt }}"
                      class="feedback-list-item-icon"
                    >
                  {% endif %}
                  {% if block.settings.series != blank %}
                    <div class="feedback-list-item-series custom-txt-semibold custom-txt-light">
                      {{ block.settings.series }}
                    </div>
                  {% endif %}
                </div>
              {% endif %}
              <img
                srcset="{{ block.settings.image | image_url: width: 300, format: 'webp' }} 500w, 
                {{ block.settings.image | image_url: width: 500, format: 'webp' }} 1200w"
                sizes="(max-width: 768px) 300px, 500px"
                width="500"
                height="500"
                loading="lazy"
                alt="{{ block.settings.image.alt }}"
              >
            </div>
            <blockquote class="feedback-list-item-context">
              {{ block.settings.context }}
            </blockquote>
            {% if section.settings.enable_author %}
              <div class="feedback-list-item-author-info">
                <div class="feedback-list-item-author-image">
                  {% if block.settings.author_image != blank %}
                    <img
                      src="{{ block.settings.author_image | image_url }}"
                      width="{{ block.settings.author_image.width }}"
                      height="{{ block.settings.author_image.height }}"
                      loading="lazy"
                      alt="{{ block.settings.author_image.alt }}"
                    >
                  {% else %}
                    <div class="author-image custom-txt-bold author-image-{% cycle '1','2','3','4','5','6','7','8','9','0' %}">
                      {{ block.settings.author_name | strip | slice: 0 | upcase }}
                    </div>
                  {% endif %}
                </div>
                <div class="feedback-list-item-author-name">
                  {{ block.settings.author_name }}
                  <span class="feedback-list-item-author-verify custom-txt-light">
                    <img
                      src="https://cdn.shopify.com/s/files/1/1001/2383/6697/files/verify.png?v=1778210846"
                      width="24"
                      height="24"
                      alt="verified buyer"
                    >
                    {{ 'general.custom.verified_buyer' | t }}
                  </span>
                </div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
      <div class="swiper-button-prev">
        <svg
          class="group-hover/svg:scale-[1.3] transition-scale duration-300 "
          xmlns="http://www.w3.org/2000/svg"
          xmlns:xlink="http://www.w3.org/1999/xlink"
          fill="none"
          version="1.1"
          width="24"
          height="24"
          viewBox="0 0 24 24"
        >
          <g><g transform="matrix(-1,0,0,1,30.833984375,0)"><path d="M15.4169921875,6.166748046875C15.4169921875,6.564568046875,15.5750271875,6.9461080468750005,15.8563321875,7.227408046875L20.6290021875,12.000078046875L15.8563321875,16.772748046875C15.5750271875,17.054048046875,15.4169921875,17.435548046875,15.4169921875,17.833448046875C15.4169921875,18.661848046875,16.0885651875,19.333448046875,16.9169921875,19.333448046875C17.3148121875,19.333448046875,17.6963521875,19.175348046875,17.9776521875,18.894048046875L23.810982187500002,13.060738046875C24.0922921875,12.779438046875,24.2503221875,12.397908046875,24.2503221875,12.000078046875C24.2503221875,11.602258046875,24.0922921875,11.220728046875,23.810982187500002,10.939418046875L17.9776521875,5.106088046875C17.6963521875,4.824783046875,17.3148121875,4.666748046875,16.9169921875,4.666748046875C16.0885651875,4.666748046875,15.4169921875,5.338321046875,15.4169921875,6.166748046875Z" fill-rule="evenodd" fill="#FFFFFF" fill-opacity="1"></path></g></g>
        </svg>
      </div>
      <div class="swiper-button-next">
        <svg
          class="group-hover/svg:scale-[1.3] transition-scale duration-300"
          xmlns="http://www.w3.org/2000/svg"
          xmlns:xlink="http://www.w3.org/1999/xlink"
          fill="none"
          version="1.1"
          width="24"
          height="24"
          viewBox="0 0 24 24"
        >
          <g><g><path d="M8.5830078125,6.166748046875C8.5830078125,6.564568046875,8.7410428125,6.9461080468750005,9.0223478125,7.227408046875L13.7950178125,12.000078046875L9.0223478125,16.772748046875C8.7410428125,17.054048046875,8.5830078125,17.435548046875,8.5830078125,17.833448046875C8.5830078125,18.661848046875,9.2545808125,19.333448046875,10.0830078125,19.333448046875C10.4808278125,19.333448046875,10.8623678125,19.175348046875,11.1436678125,18.894048046875L16.976997812500002,13.060738046875C17.2583078125,12.779438046875,17.4163378125,12.397908046875,17.4163378125,12.000078046875C17.4163378125,11.602258046875,17.2583078125,11.220728046875,16.976997812500002,10.939418046875L11.1436678125,5.106088046875C10.8623678125,4.824783046875,10.4808278125,4.666748046875,10.0830078125,4.666748046875C9.2545808125,4.666748046875,8.5830078125,5.338321046875,8.5830078125,6.166748046875Z" fill-rule="evenodd" fill="#FFFFFF" fill-opacity="1"></path></g></g>
        </svg>
      </div>
    </div>
    <p class="feedback-list-section-note custom-txt-light appear-delay{% cycle '','-1','-2','-3','-4' %}">
      {{ section.settings.feedback_list_note }}
    </p>
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const nextEl = document.querySelector('.feedback-list-section-{{ section.id }} .swiper-button-next');
    const prevEl = document.querySelector('.feedback-list-section-{{ section.id }} .swiper-button-prev');
    const feedbackListSwiper = new Swiper('.feedback-list-section-{{ section.id }} .swiper-container', {
      loop: true,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
      },
      navigation: {
        nextEl: nextEl,
        prevEl: prevEl,
      },
      slidesPerView: 1.5,
      spaceBetween: 10,
      breakpoints: {
        0: {
          slidesPerView: 1.5,
          spaceBetween: 10,
        },
        768: {
          slidesPerView: 3,
          spaceBetween: 20,
        },
        1200: {
          slidesPerView: 4,
          spaceBetween: 30,
        },
        2560: {
          slidesPerView: 5,
          spaceBetween: 30,
        },
      },
    });
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        feedbackListSwiper.update();
      }, 500);
    });
  });
</script>

{% style %}
  .feedback-list-section-{{ section.id }} {
      background-color: #fff;
      padding: 4em 0;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper {
      text-align: center;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-section-title {
      font-size: 2.4em;
      font-weight: bold;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-section-subtitle {
      font-size: 1.8em;
      font-weight: 600;
      padding: 0.6em 0;
      position: relative;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-section-subtitle::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 2px; /* 线条粗细 */
    background: linear-gradient(90deg,  transparent 45%, var(--colorThemePrimary) 45%, var(--colorThemePrimary) 55%, transparent 55% );
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-section-context {
      font-size: 1.2em;
      margin-bottom: 2em;
      color: #666;
      width: 100%;
      overflow: hidden;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-section-note {
      color: #666;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-section-content {
      width: 100%;
      padding: 1em;
      margin: 0 auto;
      overflow: hidden;
      position: relative;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-list {
      position: relative;
      width: 100%;
      height: 100%;
      display: flex;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      background: #fff;
      border-radius: 1em;
      overflow: hidden;
      box-shadow: 0 0px 10px rgba(0,0,0,0.1);
      height: auto;
      width: auto ;
      flex-shrink: 0 ;
      opacity: 1;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-image {
      width: 100%;
      aspect-ratio: 1/1;
      margin-bottom: 1.5em;
      display: grid;
      place-items: center;
      position: relative;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-image img {
      width: 100%;
      height: unset;
      aspect-ratio: 1/1;
      object-fit: cover;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-image .feedback-list-item-tag {
      position: absolute;
      top: 1em;
      left: 1em;
      padding: 0.2em 0.5em;
      border-radius: 0.5em;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #fff;
      color: var(--colorThemePrimary);
      font-size: 1em;
      font-weight: bold;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-image .feedback-list-item-icon {
      width: 2em;
      height: 2em;
      margin-right: 0.5em;
  }

  /* 🔥🔥🔥 这里就是你要的 大号特殊字体引号 🔥🔥🔥 */
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-context {
      position: relative;
      font-size: 1.1em;
      line-height: 1.6;
      text-align: left;
      padding: 1.2em 1em 1em 1em;
      margin: 0 0 1em 0;
      font-style: normal;
      /* quotes: "\201C""\201D"; */
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-context::before {
      content: "“";
      position: absolute;
      top: -0.2em;
      left: 0.1em;
      font-size: 4em;
      font-weight: 700;
      color: var(--colorThemePrimary);
      line-height: 1;
      opacity: 0.85;
      z-index: 0;
  }

  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-info {
      width: 100%;
      padding: 0.5em 1em;
      display: flex;
      align-items: center;
      margin-top: auto;
      border-top: 1px solid #f5f5f5;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-image {
      width: 4em;
      height: 4em;
      border-radius: 50%;
      margin-right: 1em;
      overflow: hidden;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-image .author-image {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: rgb(82 244 144);
      color: rgba(1,75,64,1);
      font-size: 2em;
      font-weight: bold;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-image .author-image-1 {
    background-color: #E6F0FB;
    color: #154379;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-image .author-image-2 {
    background-color: #F9E6E7;
    color: #7A2F34;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-image .author-image-3 {
    background-color: #E4F6ED;
    color: #1F6D4E;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-image .author-image-4 {
    background-color: #EDE7F8;
    color: #522E80;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-image .author-image-5 {
    background-color: #FFF9E0;
    color: #805C00;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-image .author-image-6 {
    background-color: #E9F1F3;
    color: #244952;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-image .author-image-7 {
    background-color: #F9E9E4;
    color: #75392C;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-image .author-image-8 {
    background-color: #F8F0E3;
    color: #6B4826;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-name {
      font-size: 1.5em;
      font-weight: bold;
      text-align: left;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-name span {
      display: block;
      font-size: 0.6em;
      font-weight: 300;
      color: #181818;
      margin-left: 0;
      margin-top: 0.2em;
      display: flex;
      align-items: center;
  }
  .feedback-list-section-{{ section.id }} .feedback-list-section--wrapper .feedback-list-item-author-name span img {
      width: 1em;
      height: 1em;
      margin-right: 0.2em;
  }
  /* 初始状态：所有 Swiper 容器隐藏，避免出现未格式化布局 */
  .feedback-list-section-{{ section.id }} .swiper-container {
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  /* Swiper 初始化完成后显示 */
  .feedback-list-section-{{ section.id }} .swiper-container.swiper-initialized {
    visibility: visible;
    opacity: 1;
  }

  @media screen and (max-width: 768px) {
    .feedback-list-section-{{ section.id }}  {
        font-size: 0.8em;
    }
  }
{% endstyle %}
{% schema %}
{
  "name": "Feedback List Section",
  "class": "feedback-list-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_author",
      "label": "Enable Author"
    },
    {
      "type": "text",
      "id": "feedback_list_title",
      "label": "Feedback List Title"
    },
    {
      "type": "text",
      "id": "feedback_list_subtitle",
      "label": "Feedback List Subtitle"
    },
    {
      "type": "text",
      "id": "feedback_list_context",
      "label": "Feedback List Context"
    },
    {
      "type": "text",
      "id": "feedback_list_note",
      "label": "Feedback List Note"
    }
  ],
  "blocks": [
    {
      "type": "feedback_item",
      "name": "Feedback Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "html",
          "id": "context",
          "label": "Context"
        },

        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author Image"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "series",
          "label": "Series"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feedback List Section",
      "settings": {}
    }
  ]
}
{% endschema %}
