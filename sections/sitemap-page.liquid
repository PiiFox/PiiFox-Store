{% style %}
  .sitemap-page-container {
  }
  .sitemap-page-container .sitemap-page--header {
    padding-bottom: 2em;
  }
  .sitemap-page-container .sitemap-page--header h2.sitemap-page-title {
    font-size: 2.5em;
    font-weight: bold;
    margin-bottom: 20px;
  }
  .sitemap-page-container .sitemap-page--header p.sitemap-page-description {
  }
  .sitemap-page-container .sitemap-page--wrapper {
  }
  .sitemap-page-container .sitemap-page--wrapper .sitemap-section {
    padding: 2em 0;
  }
  .sitemap-page-container .sitemap-page--wrapper .sitemap-section[data-level='1'] {
    padding-left: 1em;
  }
  .sitemap-page-container .sitemap-page--wrapper .sitemap-section[data-level='2'] {
    padding-left: 4em;
  }
  .sitemap-page-container .sitemap-page--wrapper .sitemap-section .section-title {
    font-size: 1.5em;
    font-weight: 600;
    margin-bottom: 10px;
  }
  .sitemap-page-container .sitemap-page--wrapper .sitemap-section .section-list {
  }
  .sitemap-page-container .sitemap-page--wrapper .sitemap-section .section-list ul {
  }
  .sitemap-page-container .sitemap-page--wrapper .sitemap-section .section-list ul li {
  }
  .sitemap-page-container .sitemap-page--wrapper .sitemap-section .section-list ul li a {
  }
{% endstyle %}
{% schema %}
{
  "name": "Site Map",
  "settings": [
    {
      "type": "checkbox",
      "id": "divider",
      "label": "t:sections.site-map.settings.divider.label",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "页面标题",
      "default": "Site Map"
    },
    {
      "type": "text",
      "id": "description",
      "label": "页面描述",
      "default": "Find all PIIFOX pages, product categories, support resources, policies, and brand information in one place."
    }
  ],
  "blocks": []
}
{% endschema %}

