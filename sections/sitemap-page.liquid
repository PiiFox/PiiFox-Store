{%- if section.settings.divider -%}
  <div class="section--divider">
{%- endif -%}
<div class="sitemap-page-container">
  <div class="page-width">
    <div class="sitemap-page--header">
      <h2 class="sitemap-page-title custom-txt-bold">{{ section.settings.title }}</h2>
      <p class="sitemap-page-description">{{ section.settings.description }}</p>
    </div>
    <div class="sitemap-page--wrapper">
      <section class="sitemap-section" data-level="1">
        <div class="section-title custom-txt-semibold">HOME</div>
        <div class="section-list">
          <ul>
            <li>
              <a href="{{  shop.url }}" target="_blank">HOME</a>
            </li>
          </ul>
        </div>
      </section>
      <section class="sitemap-section" data-level="1">
        <div class="section-title custom-txt-semibold">SHOP BY CATEGORY</div>
        {% liquid
          assign collections_str = 'keyboards, keycaps, switches, mice, accessories'
          assign collection_handles = collections_str | split: ', '
        %}
        <div class="section-list">
          <ul>
            {% for collection_handle in collection_handles %}
              {% assign collection = collections[collection_handle] %}
              <li>
                <a href="{{ collection.url }}" target="_blank">{{ collection.title }}</a>
              </li>
            {% endfor %}
          </ul>
        </div>
      </section>
      <section class="sitemap-section" data-level="1">
        <div class="section-title custom-txt-semibold">KEYBOARDS</div>
        <div class="section-list">
          <ul>
            <li>
              <a href="{{ collections['keyboards'].url }}/New-Arrival" target="_blank">New Arrival</a>
            </li>
            <li>
              <a href="{{ collections['keyboards'].url }}" target="_blank">Shop All Keyboards</a>
            </li>
          </ul>
        </div>
      </section>
      <section class="sitemap-section" data-level="2" data-parent="Keyboards" data-param="Layout Size">
        <div class="section-title custom-txt-semibold">By Size</div>
        <div class="section-list">
          <ul>
            {% comment %}固定目标集合：keyboards{% endcomment %}
            {% assign target_col = collections.keyboards %}
            {% assign filter_key = 'Layout Size' %}
            {% assign target_filter = target_col.filters | where: 'label', filter_key | first %}

            {% comment %}循环Layout Size所有可选值{% endcomment %}
            {% if target_filter and target_filter.values.size > 0 %}
              {% for val in target_filter.values %}
                <li>
                  {% comment %}拼接标准筛选参数：filter.p.m.custom.字段名=值（Shopify原生筛选URL格式）{% endcomment %}
                  {% assign filter_url = target_col.url
                    | append: '?filter.p.m.custom.'
                    | append: target_filter.param
                    | append: '='
                    | append: val
                    | url_escape
                  %}
                  <a href="{{ filter_url }}" target="_blank">{{ val }}</a>
                </li>
              {% endfor %}
            {% endif %}
          </ul>
        </div>
      </section>
