{%- if section.settings.divider -%}

<div class="page-width">
  <div class="support-us-box">
    <h2>{{ section.settings.title }}</h2>
    <div class="container">
    {% for block in section.blocks  %}
      {%- if block.type == 'text' -%}
        <a href="{{ block.settings.link }}">
          <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.image.alt }}">
          <p>{{ block.settings.usname }}</p>
        </a>
      {% endif %}
    {% endfor %}  
    </div>
  </div>
</div>
<style>
.support-us-box{margin-top:10rem;text-align:center;margin-bottom:10rem;}
.support-us-box h2{font-weight:400;margin-bottom:5rem;}
.support-us-box img{width:64px;}
.support-us-box .container{display:flex;justify-content:center;}
.support-us-box a{padding:0 2rem;}
@media screen and (max-width: 750px) {
  .support-us-box{margin-top:5rem;}
  .support-us-box h2{font-size:1.4rem;margin-bottom:2rem;}
}
</style>
{%- endif -%}


{% schema %}
{
  "name": "t:sections.support-us.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "divider",
      "label": "t:sections.support-us.settings.divider",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.support-us.settings.title"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "t:sections.support-us.blocks.column.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.support-us.blocks.column.settings.image"
        },
        {
          "type": "text",
          "id": "usname",
          "label": "t:sections.support-us.blocks.column.settings.text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.support-us.blocks.column.settings.url"
        }
      ]
    }
  ]
}
{% endschema %}