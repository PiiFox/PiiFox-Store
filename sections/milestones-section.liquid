{% comment %}
  里程碑时间线组件 - 带左右切换按钮
{% endcomment %}

<style>
  .milestones-section {
    padding: 60px 20px;
    margin: 0 auto;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    position: relative;
  }

  .milestones-section__title {
    text-align: center;
    font-size: 32px;
    font-weight: 600;
    margin-bottom: 40px;
    color: #000;
  }

  .milestones-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2em;
    margin-bottom: 2em;
  }

  .milestones-timeline {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    width: calc(100% - 80px);
  }

  .milestones-timeline::before {
    content: '';
    position: absolute;
    top: -10%;
    left: 0;
    right: 0;
    height: 2px;
    background: #e0e0e0;
    transform: translateY(-50%);
    z-index: 0;
  }

  .milestones-timeline__progress {
    position: absolute;
    top: -10%;
    left: 0;
    height: 2px;
    background: var(--colorThemePrimary);
    transform: translateY(-50%);
    z-index: 0;
    transition: width 0.3s ease;
  }

  .milestones-timeline__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 1;
    cursor: pointer;
    top: -10px;
  }

  /* 圆点完美居中在时间线上 */
  .milestones-timeline__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ccc;
    transition: all 0.3s ease;
    position: relative;
  }

  /* 波纹动画 */
  .milestones-timeline__item.active .milestones-timeline__dot::after {
    content: '';
    position: absolute;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(66, 115, 71, 0.2);
    animation: ripple 0.8s ease-out infinite;
    left: 0;
    top: 0;
  }

  @keyframes ripple {
    0% {
      transform: scale(1);
      opacity: 1;
    }
    100% {
      transform: scale(2.5);
      opacity: 0;
    }
  }

  .milestones-timeline__item.active .milestones-timeline__dot {
    background: var(--colorThemePrimary);
    box-shadow: 0 0 0 3px rgba(66, 115, 71, 0.2);
  }

  .milestones-timeline__date {
    font-size: 16px;
    color: #666;
    transition: all 0.3s ease;
    margin-top: 12px;
  }

  .milestones-timeline__item.active .milestones-timeline__date {
    color: var(--colorThemePrimary);
    font-weight: 500;
  }

  .milestones-nav {
    display: flex;
    gap: 10px;
  }

  /* 按钮箭头完美居中 */
  .milestones-nav__btn {
    font-size: 2.5em;
    width: 1.3em;
    height: 1.3em;
    padding: 0;
    box-sizing: border-box;
    border-radius: 50%;
    border: none;
    color: #333;
    background: #fff;
    box-shadow: 0 0px 8px rgba(0, 0, 0, 0.1);
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: all 0.2s;
    text-align: center;
  }

  .milestones-nav__btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .milestones-nav__btn:hover:not(:disabled) {
    background: #f5f5f5;
  }

  .milestones-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .milestones-card__image img {
    width: 100%;
    height: unset;
    aspect-ratio: 1/1;
    object-fit: cover;
    display: block;
  }

  .milestones-card__content {
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .milestones-card__date {
    font-size: 18px;
    color: var(--colorThemePrimary);
    font-weight: 500;
    margin-bottom: 16px;
  }

  .milestones-card__title {
    font-size: 36px;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 20px;
    color: #000;
  }

  .milestones-card__desc {
    font-size: 18px;
    line-height: 1.7;
    color: #555;
    margin-bottom: 30px;
  }

  .milestones-card__link {
    display: inline-flex;
    align-items: center;
    font-size: 18px;
    font-weight: 500;
    color: var(--colorThemePrimary);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .milestones-card__link:hover {
    opacity: 0.8;
  }

  .milestones-card__link::after {
    content: '→';
    margin-left: 8px;
    font-size: 20px;
  }

  /* 响应式适配 */
  @media (max-width: 768px) {
    .milestones-section {
      padding: 0;
    }
    .milestones-header {
      flex-direction: column;
      gap: 20px;
    }
    .milestones-timeline {
      width: 100%;
      overflow-x: auto;
      padding-bottom: 10px;
    }
    /* Chrome/Safari/新版Edge */
    .milestones-timeline::-webkit-scrollbar {
      display: none;
      width: 0;
      height: 0;
    }
    .milestones-timeline__progress {
      top: 25%;
    }
    .milestones-timeline__item {
      min-width: 80px;
      top: 10px;
      margin: 0 2em;
    }
    .milestones-card {
      grid-template-columns: 1fr;
    }
    .milestones-card__content {
      padding: 2em 1em;
    }
    .milestones-card__title {
      font-size: 28px;
    }
    .milestones-section__title {
      font-size: 26px;
    }
  }
</style>

<section class="milestones-section milestones-section--{{ section.id }} wow bounceInUp">
  <div class="page-width">
    <h2 class="milestones-section__title">{{ section.settings.title }}</h2>

    <!-- 头部：时间线 + 左右按钮 -->
    <div class="milestones-header">
    <div class="milestones-timeline">
      <div class="milestones-timeline__progress"></div>
      {% for milestone in section.blocks %}
        <div
          class="milestones-timeline__item {% if forloop.index == 1 %}active{% endif %}"
          data-index="{{ forloop.index0 }}"
        >
          <div class="milestones-timeline__dot"></div>
          <span class="milestones-timeline__date">{{ milestone.settings.date }}</span>
        </div>
      {% endfor %}
    </div>

    <div class="milestones-nav">
      <button class="milestones-nav__btn prev-btn" aria-label="上一个">‹</button>
      <button class="milestones-nav__btn next-btn" aria-label="下一个">›</button>
    </div>
    </div>

    <!-- 里程碑卡片 -->
    <div class="milestones-card">
    {% assign first_milestone = section.blocks.first %}
    <div class="milestones-card__image">
      {% if first_milestone.settings.image != blank %}
        <img
          src="{{ first_milestone.settings.image | image_url }}"
          alt="{{ first_milestone.settings.title }}"
          width="800"
          height="600"
        >
      {% else %}
        <img
          src="{{ 'placeholder-img.svg' | asset_url | img_url }}"
          alt="{{ first_milestone.settings.title }}"
          width="800"
          height="600"
        >
      {% endif %}
    </div>
    <div class="milestones-card__content">
      <p class="milestones-card__date custom-txt-semibold">{{ first_milestone.settings.date }}</p>
      <h3 class="milestones-card__title custom-txt-bold">{{ first_milestone.settings.title }}</h3>
      <p class="milestones-card__desc">{{ first_milestone.settings.description }}</p>
      {% if first_milestone.settings.link != blank %}
        <a href="{{ first_milestone.settings.link }}" class="milestones-card__link custom-txt-semibold">
          {{- section.settings.btn_label -}}
        </a>
      {% endif %}
    </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('.milestones-section--{{ section.id }}');
    if (!section) return;

    const items = section.querySelectorAll('.milestones-timeline__item');
    const card = section.querySelector('.milestones-card');
    const progressBar = section.querySelector('.milestones-timeline__progress');
    const prevBtn = section.querySelector('.prev-btn');
    const nextBtn = section.querySelector('.next-btn');

    // 把区块数据转成JSON
    const milestonesData = [
      {% for block in section.blocks %}
        {
          index: {{ forloop.index0 }},
          date: {{ block.settings.date | json }},
          title: {{ block.settings.title | json }},
          description: {{ block.settings.description | json }},
          image: {{ block.settings.image | image_url | json }},
          link: {{ block.settings.link | json }}
        }{% if forloop.last %}{% else %},{% endif %}
      {% endfor %}
    ];

    let currentIndex = 0;

    // 更新进度条和按钮状态
    function updateUI() {
      const currentEl = document.querySelector(`.milestones-timeline__item[data-index="${currentIndex}"]`);
      const dotEl = currentEl.querySelector('.milestones-timeline__dot');
      const timeline = section.querySelector('.milestones-timeline');
      // 更新时间线进度条宽度
      const progressWidth = (currentEl.offsetLeft + dotEl.offsetLeft) / timeline.offsetWidth * 100;
      progressBar.style.width = `${progressWidth}%`;

      // =============================================
      // ✅ 自动滚动到当前激活项（居中显示，手机/电脑通用）
      currentEl.scrollIntoView({
        behavior: 'smooth',
        block: 'nearest',
        inline: 'center'
      });

      // 更新按钮状态
      prevBtn.disabled = currentIndex === 0;
      nextBtn.disabled = currentIndex === items.length - 1;

      // 更新active状态
      items.forEach((item, index) => {
        item.classList.toggle('active', index === currentIndex);
      });

      // 更新卡片内容
      const data = milestonesData[currentIndex];
      card.querySelector('.milestones-card__date').textContent = data.date;
      card.querySelector('.milestones-card__title').textContent = data.title;
      card.querySelector('.milestones-card__desc').textContent = data.description;
      card.querySelector('.milestones-card__image img').src = data.image;

      const linkEl = card.querySelector('.milestones-card__link');
      if (linkEl && data.link) {
        linkEl.href = data.link;
      } else if (linkEl) {
        linkEl.style.display = 'none';
      }
    }

    // 点击时间线项目切换
    items.forEach((item, index) => {
      item.addEventListener('click', () => {
        currentIndex = index;
        updateUI();
      });
    });

    // 上一个
    prevBtn.addEventListener('click', () => {
      if (currentIndex > 0) {
        currentIndex--;
        updateUI();
      }
    });

    // 下一个
    nextBtn.addEventListener('click', () => {
      if (currentIndex < items.length - 1) {
        currentIndex++;
        updateUI();
      }
    });

    // 初始化
    updateUI();
  });
</script>

{% schema %}
{
  "name": "Milestones",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "标题",
      "default": "Our Milestones"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "按钮文本",
      "default": "Learn More"
    }
  ],
  "blocks": [
    {
      "type": "milestone_item",
      "name": "Milestone Item",
      "settings": [
        {
          "type": "text",
          "id": "date",
          "label": "日期（如 2025.01）"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "图片"
        },
        {
          "type": "text",
          "id": "title",
          "label": "标题"
        },
        {
          "type": "text",
          "id": "description",
          "label": "描述内容"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Learn More 链接"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Milestones",
      "category": "custom"
    }
  ]
}
{% endschema %}
