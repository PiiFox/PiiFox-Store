  <script>
const slider_bar = document.querySelector(".progressbar-slide");
const swiperItems = document.querySelectorAll(".swiper-slide");
function scrollRule(activeBullet) {
  let activeIndex = activeBullet.dataset.index;
  let activeLeft = activeBullet.offsetLeft;

  let paginationEl = document.querySelector(".swiper-pagination");
  let swiperList = document.querySelectorAll(".swiper-pagination-bullet");

  if(activeIndex < 4) {
    paginationEl.style.transform = 'translateX(0px)';
    slider_bar.style.transform = 'translateX('+ activeLeft +'px)';
  } else if(swiperList.length - 1 - activeIndex < 4) {
    let diff = swiperList.length < 8 ? 0 : swiperList.length - 8;
    let pageLeft = diff * activeBullet.clientWidth;
    paginationEl.style.transform = 'translateX('+ (-1 * pageLeft) +'px)';
    slider_bar.style.transform = 'translateX('+ (activeLeft - pageLeft) +'px)';
  } else {
    slider_bar.style.transform = 'translateX('+ (3 * activeBullet.clientWidth) +'px)';
    paginationEl.style.transform = 'translateX('+ (-1 * (activeIndex - 3) * activeBullet.clientWidth) +'px)';
    
  }
}
const swiper = new Swiper(".swiper", {
  loop: true,
  autoplay: {
    delay: 5000,
    disableOnInteraction: false
  },
  on:{
    autoplay: () => {
      scrollRule(document.querySelector(".swiper-pagination-bullet.swiper-pagination-bullet-active"));
    },
    slideChangeTransitionStart: function(){
      let activeBullet = document.querySelector(".swiper-pagination-bullet.swiper-pagination-bullet-active");
      activeBullet && scrollRule(activeBullet);
    },
  }, 
  navigation: {
    nextEl: ".swiper-button-next",
    prevEl: ".swiper-button-prev",
    enabled: false
  },
  pagination: {
    el: ".swiper-pagination",
    clickable: true, 
    renderBullet: function (index, className) {
      let data = window.matchMedia('(max-width: 550px)').matches ? swiperItems[index].dataset.time.slice(2) : swiperItems[index].dataset.time;
      return '<div class="' + className + '" data-index="' + index + '">' + data + "</div>";
    }
  },
});
$(function() {
  let slide_left = document.querySelector(".swiper-pagination-bullet:first-child").offsetLeft;
  slider_bar.style.transform = 'translateX(' + slide_left + "px)";
})
let bullets = document.querySelectorAll('.swiper-pagination-bullet');
for(let i = 0; i < bullets.length; i++ ) {
  bullets[i].addEventListener('click', (event) => {
    scrollRule(event.target);
  })
}
  </script>
