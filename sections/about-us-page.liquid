<style>
.about-us-container-{{ section.id }} .page-width--narrow{max-width:1400px}
.about-us-container-{{ section.id }} .page-full,.about-us-container-{{ section.id }} .page-width{padding:0}
.text-left.page-width{padding:0 1rem;box-sizing:content-box}
.milestone{background:#000;color:#fff}
.milestone h3{font-size: 3rem;padding: 4rem 1.3rem 2rem;font-weight: 600;}
.progressbar-track{background:linear-gradient(to bottom,transparent,#fff);height:4px;margin:0 auto;overflow-x:hidden;position:relative;top:3rem}
.progressbar-slide{width:calc(100% / 8);height:4px;background:#eb6f20;transform:translateX(0);transition:all .6s ease}
h3{width:100%;margin:0 auto;padding:1rem 0}
.swiper{width:100%;height:100%;overflow-x:hidden}
.swiper-slide{display:flex;align-items:center;padding:8rem 0 6rem 0}
.swiper-slide .thumb-img{margin:0 3rem 0 1rem;width:30rem;min-width:30rem;height:30rem;background:#fff;border-radius:1.5rem}
.swiper-slide .time-node-info{width:calc(100% - 26rem);max-width:calc(100% - 26rem);word-wrap:break-word;margin:0 1rem}
.swiper-slide .thumb-img img{width:100%;height:100%;border-radius:1.5rem;object-fit:contain}
.swiper-slide .time-node-info .title{padding:.8rem 0 1rem;font-size:1.8rem;font-weight:600}
.swiper-slide .time-node-info .describe{line-height:1.8rem;font-weight:400;color:#bbb}
.swiper-pagination{bottom:unset;top:.3rem;left:0;position:absolute;white-space:nowrap;transform:translateX(0);transition:all .6s ease}
.swiper-pagination-bullet{width:calc(100% / 8);height:20px;text-align:center;line-height:20px;font-size:1.2rem;color:rgba(255,255,255,.6);opacity:1;border-radius:0;background:0 0;margin:0!important}
.swiper-pagination-bullet-active{color:#fff;background:0 0}
@media screen and (max-width:980px){.text-left.page-width{padding:0 1rem}
.milestone-title,.progressbar-track{width:96%}
.swiper-horizontal>.swiper-pagination-bullets,.swiper-pagination-bullets.swiper-pagination-horizontal,.swiper-pagination-custom,.swiper-pagination-fraction{width:96%;margin:0 2%}
.swiper-slide .thumb-img{margin-right:2%;margin-left:1rem}
.swiper-slide .time-node-info{margin-right:1rem}
.text-with-icons__blocks{flex-direction:row}
.text-with-icons__blocks .text-with-icons__block{width:50%}
}
@media screen and (max-width:750px){
.support-background-box .context{display:grid;place-items:center;text-align:center}
.swiper-pagination-bullet{font-size:1rem}
.swiper-slide{padding:6rem 1rem 2rem}
.swiper-pagination{height:4rem;}
}
@media screen and (max-width:650px){.swiper-slide{display:block}
.swiper-slide .thumb-img{margin:0;width:100%;aspect-ratio:1/1;height:unset;border-radius:0;min-width:auto;border-radius:1rem;}
.swiper-slide .thumb-img img{border-radius:0}
.swiper-slide .time-node-info{width:calc(100% - 2rem);max-width:calc(100% - 2rem);margin:0 1rem;}
}
@media screen and (max-width:450px){.swiper-pagination-bullet{font-size:.6rem}
}

