<div class="icon-list-marquee-section-{{ section.id }}">
  <div class="icon-list-marquee--wrapper page-width">
    <div class="icon-list-marquee-section-content">
      <div class="icon-list-marquee-container">
        <div class="icon-list-marquee">
          {% for block in section.blocks %}
            <div class="icon-item">
              <img
                class="icon-item-icon"
                src="{{ block.settings.icon | image_url }}"
                alt="{{ block.settings.context }}"
                width="40"
                height="40"
                loading="lazy"
              >
              <div class="icon-item-context custom-txt-semibold">{{ block.settings.context }}</div>
            </div>
          {% endfor %}
        </div>

        <!-- 关键：复制一份，实现无缝 -->
        <div class="icon-list-marquee overflow-hidden">
          {% for block in section.blocks %}
            <div class="icon-item">
              <img
                class="icon-item-icon"
                src="{{ block.settings.icon | image_url }}"
                alt="{{ block.settings.context }}"
                width="40"
                height="40"
                loading="lazy"
              >
              <div class="icon-item-context custom-txt-semibold">{{ block.settings.context }}</div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% style %}
  .icon-list-marquee-section-{{ section.id }} {
    background-color: #f5f5f7;
    padding: 2em 0;
  }
  .icon-list-marquee-section-{{ section.id }} .icon-list-marquee--wrapper {

  }
  .icon-list-marquee-section-{{ section.id }} .icon-list-marquee-section-title {
    font-size: 2.4em;
    font-weight: bold;
    text-align: center;
    margin-bottom: 1em;
  }
  .icon-list-marquee-section-{{ section.id }} .icon-list-marquee-section-content {
    width: 100%;
    overflow: hidden;
  }
  .icon-list-marquee-section-{{ section.id }} .icon-list-marquee-container {
    display: flex;
    width: 100%;
  }
  .icon-list-marquee-section-{{ section.id }} .icon-list-marquee {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 4em; /* 图标之间的间距 */
    padding: 0 1em;
  }
  .icon-list-marquee-section-{{ section.id }} .icon-list-marquee.overflow-hidden {
    display: none;
  }
  .icon-list-marquee-section-{{ section.id }} .icon-item {
    display: flex;
    align-items: center;
    white-space: nowrap;
  }
  .icon-list-marquee-section-{{ section.id }} .icon-item-icon {
    width: 1.2em;
    height: 1.2em;
    object-fit: cover;
  }
  .icon-list-marquee-section-{{ section.id }} .icon-item-context {
    font-size: 1em;
    margin-left: 0.5em;
    line-height: 1.2em;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  @media screen and (max-width: 1440px) {
    .icon-list-marquee-section-{{ section.id }} .icon-list-marquee-container {
      width: max-content;
      animation: marquee {{ section.settings.scroll_speed }}s linear infinite; 
    }
    .icon-list-marquee-section-{{ section.id }} .icon-list-marquee {
      width: unset;
    }
    .icon-list-marquee-section-{{ section.id }} .icon-list-marquee.overflow-hidden {
      display: flex;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Icon List Marquee Section",
  "class": "icon-list-marquee-section",
  "settings": [
    {
      "type": "text",
      "id": "icon_list_title",
      "label": "Title"
    },
    {
      "type": "number",
      "id": "scroll_speed",
      "label": "Scroll Speed",
      "default": 18
    }
  ],
  "blocks": [
    {
      "type": "icon_item",
      "name": "Icon Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "context",
          "label": "Context"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icon List Marquee Section",
      "settings": {}
    }
  ]
}
{% endschema %}
