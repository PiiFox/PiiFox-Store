{% assign section_collection = section.settings.collection %}
{% assign product_count = section_collection.products | size %}

{% style %}
  .keycap-section-wrapper {
    width: 100%;
    padding: 2em 1em;
    box-sizing: border-box;
  }
  .keycap-section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.2em;
    flex-wrap: wrap;
  }
  .keycap-section-title {
    font-size: 2em;
    font-weight: 600;
    margin: 0;
  }
  .keycap-view-all-btn {
    padding: 0.6em 1.4em;
    border: 1px solid #000;
    border-radius: 20em;
    text-decoration: none;
    color: #000;
    font-size: 1em;
    transition: all 0.2s ease;
  }
  .keycap-view-all-btn:hover {
    background: #000;
    color: #fff;
  }
  .keycap-carousel {
    display: flex;
    gap: 1.4em;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding-bottom: 1em;
    scrollbar-width: thin;
  }
  .keycap-product-card {
    min-width: 340px;
    max-width: 340px;
    border-radius: 1em;
    overflow: hidden;
    background: #fff;
    flex-shrink: 0;
  }
  .keycap-card-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .keycap-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .keycap-card-info {
    padding: 1em;
  }
  .keycap-product-name {
    font-size: 1.4em;
    font-weight: 500;
    margin: 0 0 12px 0;
  }
  .keycap-shopnow-btn {
    display: inline-block;
    padding: 0.5em 1.2em;
    border: 1px solid #000;
    border-radius: 20em;
    text-decoration: none;
    color: #000;
    font-size: 0.9em;
  }
  .carousel-arrow-wrap {
    display: flex;
    gap: 0.5em;
    position: relative;
    top: -4.5em;
    justify-content: flex-end;
    margin-right: 0.5em;
  }
  .carousel-arrow {
    width: 3em;
    height: 3em;
    border-radius: 50%;
    border: none;
    background: #f0f0f0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
  }
  .carousel-arrow:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }
{% endstyle %}

<div class="keycap-section-wrapper">
  <div class="page-width">
    <div class="keycap-section-header">
      <h2 class="keycap-section-title">
        {{ section_collection.title }}
        <span>({{ product_count }})</span>
      </h2>
      <a href="{{ section_collection.url }}" class="keycap-view-all-btn">
        {{- 'collections.general.all_of_collection' | t -}}
      </a>
    </div>

    <div class="keycap-carousel" id="keycapCarousel-{{ section.id }}">
      {% for product in section_collection.products %}
        <div class="keycap-product-card">
          <div class="keycap-card-img-wrap">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 680 }}"
                alt="{{ product.title | escape }}"
                class="keycap-card-img"
                loading="lazy"
                width="680"
                height="auto"
              >
            {% else %}
              <div style="width:100%;height:100%;background:#f7f7f7;display:flex;align-items:center;justify-content:center;">
                No Image
              </div>
            {% endif %}
          </div>
          <div class="keycap-card-info">
            <h3 class="keycap-product-name">{{ product.title }}</h3>
            <a href="{{ product.url }}" class="keycap-shopnow-btn">Shop Now</a>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="carousel-arrow-wrap">
      <button class="carousel-arrow prev-arrow" data-target="keycapCarousel-{{ section.id }}">←</button>
      <button class="carousel-arrow next-arrow" data-target="keycapCarousel-{{ section.id }}">→</button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const arrows = document.querySelectorAll('.carousel-arrow');
    arrows.forEach((btn) => {
      btn.addEventListener('click', () => {
        const carouselId = btn.dataset.target;
        const carouselEl = document.getElementById(carouselId);
        const scrollStep = 360;

        if (btn.classList.contains('prev-arrow')) {
          carouselEl.scrollBy({ left: -scrollStep, behavior: 'smooth' });
        } else {
          carouselEl.scrollBy({ left: scrollStep, behavior: 'smooth' });
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Style Keycap Section",
  "tag": "section",
  "class": "keycap-style-section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "collection"
    }
  ],
  "presets": [
    {
      "name": "Style Keycap Section",
      "settings": {
        "collection": ""
      }
    }
  ]
}
{% endschema %}
