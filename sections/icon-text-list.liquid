        "id": "divider",
        "label": "t:sections.icon_text.settings.divider.label",
        "default": true
      }, {
        "type": "text",
        "id": "title",
        "label": "t:sections.icon_text.settings.title.label"
      }
    ],
    "blocks": [
      {
        "type": "text",
        "name": "t:sections.icon_text.blocks.column.name",
        "settings": [
