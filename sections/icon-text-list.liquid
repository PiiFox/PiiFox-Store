            }
          },
          {
            "type": "text",
            "settings": {
              "title": "Enter Title",
              "desc": "Enter Describe"
            }
          }, {
            "type": "text",
            "settings": {
              "title": "Enter Title",
              "desc": "Enter Describe"
            }
          }, {
            "type": "text",
            "settings": {
              "title": "Enter Title",
              "desc": "Enter Describe"
            }
          }
        ]
      }
    ]
  }
{% endschema %}