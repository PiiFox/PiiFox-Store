    },
    {
      "type": "page",
      "id": "page",
      "label": "t:product_block.tab.settings.page.label"
    }
  ]
},
{
  "type": "coupon",
  "name": "t:product_block.coupon.name",
  "settings": [
    {
      "type": "number",
      "id": "timezone",
      "label": "TimeZone"
    },
    {
      "type": "select",
      "id": "coupon_template",
