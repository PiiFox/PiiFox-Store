        "label": "Collection"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "checkbox",
        "id": "viewMore",
        "label": "View More"
      },
      {
        "type": "url",
        "id": "moreURL",
        "label": "More URL"
      }
    ],
    "blocks": [
      {
        "type": "text",
        "name": "Column",
        "settings": [
          {
            "type": "text",
            "id": "subtitle",
            "label": "Sub Title",
            "default": "Sub Title"
          }, {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Title"
          }, {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          }, {
            "type": "url",
            "id": "link",
            "label": "Link"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Video tab",
        "blocks": [
          {
          "type": "text"
          },
          {
          "type": "text"
          },
          {
          "type": "text"
          }
        ]
      }
    ]
  }
{% endschema %}