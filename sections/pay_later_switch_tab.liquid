            }
          },
          {
            "type": "text",
            "settings": {
              "name": "Step 2",
              "title": "Enter Title",
              "describe": "Enter Describe"
            }
          },
          {
            "type": "text",
            "settings": {
              "name": "Step 3",
              "title": "Enter Title",
              "describe": "Enter Describe"
            }
          },
          {
            "type": "text",
            "settings": {
              "name": "Step 4",
              "title": "Enter Title",
              "describe": "Enter Describe"
            }
          }
        ]
      }
    ]
  }
{% endschema %}

