<div class="main-collection-list-section-{{ section.id }} wow bounceInUp">
  <div class="main-collection-list-section--wrapper page-width">
    <h2 class="main-collection-list-section-title custom-txt-bold appear-delay{% cycle '','-1','-2','-3','-4' %}">
      {{ section.settings.title }}
    </h2>
    <div class="main-collection-list-section--content">
      {% for block in section.blocks %}
        {% style %}
          .main-collection-list-item-{{ block.id }} {
              background-image: url({{ block.settings.cover_image | image_url: width: 1000, format: 'webp'  }});
              background-size: cover;
              background-position: center;
          }
          @media screen and (max-width: 768px) {
            .main-collection-list-item-{{ block.id }} {
              background-image: url({{ block.settings.cover_image_m | image_url: width: 768, format: 'webp'  }});
            }
          }
        {% endstyle %}
        {% assign collection = collections[block.settings.collection] %}
        {% if collection %}
          <a
            href="{{ collection.url }}"
            class="main-collection-list-item main-collection-list-item-{{ forloop.index }} main-collection-list-item-{{ block.id }} appear-delay{% cycle '','-1','-2','-3','-4' %}"
          >
            <div class="main-collection-list-item-header">
              <div class="main-collection-list-item-title custom-txt-bold">{{ block.settings.collection_title }}</div>
              <svg
                class="group-hover/svg:scale-[1.3] transition-scale duration-300"
                xmlns="http://www.w3.org/2000/svg"
                xmlns:xlink="http://www.w3.org/1999/xlink"
                fill="none"
                version="1.1"
                width="24"
                height="24"
                viewBox="0 0 24 24"
              >
                <g><g><path d="M8.5830078125,6.166748046875C8.5830078125,6.564568046875,8.7410428125,6.9461080468750005,9.0223478125,7.227408046875L13.7950178125,12.000078046875L9.0223478125,16.772748046875C8.7410428125,17.054048046875,8.5830078125,17.435548046875,8.5830078125,17.833448046875C8.5830078125,18.661848046875,9.2545808125,19.333448046875,10.0830078125,19.333448046875C10.4808278125,19.333448046875,10.8623678125,19.175348046875,11.1436678125,18.894048046875L16.976997812500002,13.060738046875C17.2583078125,12.779438046875,17.4163378125,12.397908046875,17.4163378125,12.000078046875C17.4163378125,11.602258046875,17.2583078125,11.220728046875,16.976997812500002,10.939418046875L11.1436678125,5.106088046875C10.8623678125,4.824783046875,10.4808278125,4.666748046875,10.0830078125,4.666748046875C9.2545808125,4.666748046875,8.5830078125,5.338321046875,8.5830078125,6.166748046875Z" fill-rule="evenodd" fill="#FFFFFF" fill-opacity="1"></path></g></g>
              </svg>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>
{% style %}
  .main-collection-list-section-{{ section.id }} {
      padding: 4em 0;
      background-color: #fff;

  }
  .main-collection-list-section-{{ section.id }} .main-collection-list-section-title {
      font-size: 2.5em;
      font-weight: bold;
      text-align: left;
      margin-bottom: 30px;
  }
  .main-collection-list-section-{{ section.id }} .main-collection-list-section--content {
      display: grid;
      gap: 1em;
      grid-template-columns: 753fr 763fr 775fr;
      grid-template-rows: 823fr 581fr;
  }
  .main-collection-list-section-{{ section.id }} .main-collection-list-item {
      display: inline-flex;
      flex-direction: column;
      justify-content: flex-end;
      text-decoration: none;
      color: #fff;
      border-radius: 10px;
      overflow: hidden;
      background-color: #fff;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      transition: background-size 0.3s ease;
      overflow: hidden;
  }
  .main-collection-list-section-{{ section.id }} .main-collection-list-item-1 {
      grid-column: 1 / 3;
      grid-row: 1 / 2;
      aspect-ratio: 1555/823;
  }
  .main-collection-list-section-{{ section.id }} .main-collection-list-item:hover {
      background-size: 120%;
  }
  .main-collection-list-section-{{ section.id }} .main-collection-list-item-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1em;
  }
  .main-collection-list-section-{{ section.id }} .main-collection-list-item-title {
      font-size: 1.2em;
      font-weight: bold;
  }
  @media screen and (max-width: 768px) {
        .main-collection-list-section-{{ section.id }}{
            font-size: 0.8em;
        }
      .main-collection-list-section-{{ section.id }} .main-collection-list-section--content {
          grid-template-columns: 1fr;
          grid-template-rows: repeat(5, 1fr);
      }
      .main-collection-list-section-{{ section.id }} .main-collection-list-item-1 {
          grid-column: 1 / 2;
          grid-row: 1 / 2;
      }
  }
{% endstyle %}

{% schema %}
{
  "name": "Main Collection List",
  "class": "main-collection-list-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "SHOP BY CATEGORY"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "cover_image",
          "label": "Cover Image"
        },
        {
          "type": "image_picker",
          "id": "cover_image_m",
          "label": "Mobile Cover Image"
        },
        {
          "type": "text",
          "id": "collection_title",
          "label": "Collection Title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main Collection List",
      "settings": {
        "title": "SHOP BY CATEGORY"
      },
      "blocks": []
    }
  ]
}
{% endschema %}
