                </div>
              </div>
            </div>
            <div class="con3-right--wrapper">
              {% if con4_video.settings.video %}
                {% assign con4_video_url = con4_video.settings.video.sources | first | map: 'url' %}
                <video
                  width="100%"
                  height="auto"
                  muted
                  autoplay
                  loop
                  playsinline
                  preload="metadata"
                  poster="{{ con4_video.settings.video_thumbnail | image_url }}"
                >
                  <source src="{{ con4_video_url }}" type="application/x-mpegURL">
                  <img
                    width="680"
                    height="auto"
                    src="{{ con4_video.settings.video_thumbnail | image_url: width:680, format: 'webp' }}"
                    srcset="
                      {{ con4_video.settings.video_thumbnail | image_url: width:680, format: 'webp' }} 680w,
                      {{ con4_video.settings.video_thumbnail | image_url: width:1920, format: 'webp' }} 1920w
                    "
                    sizes="(max-width: 768px) 680px, 1920px"
                    alt="{{ con4_video.settings.video_thumbnail.alt }}"
                    loading="lazy"
                    class="con4-video-thumbnail"
                  >
                </video>
              {% else %}
                <div class="con4-video-thumbnail">
                  <img
                    width="680"
                    height="auto"
                    src="{{ con4_video.settings.video_thumbnail | image_url: width:680, format: 'webp' }}"
                    srcset="
                      {{ con4_video.settings.video_thumbnail | image_url: width:680, format: 'webp' }} 680w, 
                      {{ con4_video.settings.video_thumbnail | image_url: width:1920, format: 'webp' }} 1920w  
                    "
                    sizes="(max-width: 768px) 680px, 1920px"
                    loading="lazy"
                    class="con4-video-thumbnail"
                  >
                </div>
              {% endif %}
              {% if con4_content %}
                <div class="con4-content">
                  <div class="con4-block1 con4-block">
                    {{ con4_content.settings.block1 }}
                  </div>
                  <div class="con4-block2 con4-block">
                    {{ con4_content.settings.block2 }}
                  </div>
                  <div class="con4-block3 con4-block">
                    {{ con4_content.settings.block3 }}
                  </div>
                  <div class="con4-block4 con4-block">
                    {{ con4_content.settings.block4 }}
                  </div>
                  <div class="con4-block5 con4-block">
