<div class="about-us-section-{{ section.id }}-cache-area"></div>
<script>
  /**
   * 滚动视差动画:
   * 首屏文字
   * 自动播放视频2
   * 首屏Title 放大 淡化
   * 自动播放视频3
   * 自动播放视频4, 显示内容
   * 上移第五部分文字
   **/
  const video = document.querySelector('.con2-video video');
  if (video) {
    video.load();
    video.play().catch((e) => console.log('play error', e));
  }
</script>
<script src="{{ 'gsap.min.js' | asset_url }}" defer></script>
<script src="{{ 'ScrollTrigger.min.js' | asset_url }}" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    gsap.registerPlugin(ScrollTrigger);

    let aboutus_scrollModule = document.querySelector('.about-us-section-{{ section.id }}');
    aboutus_scrollModule.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      window.location.href = '/pages/about-us';
    });

    const aboutus_timeline = gsap.timeline({
      scrollTrigger: {
        trigger: '.about-us-section-{{ section.id }}',
        start: 'top 0%',
        end: '+=300%',
        pin: true,
        scrub: 2.5,
      },
    });

    aboutus_timeline
      .set('.about-us-section-{{ section.id }} .con1-content .con1-title', {
        scale: 1,
        transformOrigin: 'center center',
      })
      .set('.about-us-section-{{ section.id }} .con1-content', {
        autoAlpha: 1,
      })
      .set('.about-us-section-{{ section.id }} .con1-content-front', {
        autoAlpha: 1,
      })
      .set('.about-us-section-{{ section.id }} .con3-left--wrapper', {
        autoAlpha: 0,
      });

    aboutus_timeline
      .to('.about-us-section-{{ section.id }} .con1-content .con1-title', {
        scale: 8,
        duration: 3.5,
        ease: 'power2.out',
      })
      .to(
        '.about-us-section-{{ section.id }} .con1-content',
        {
          autoAlpha: 0,
          duration: 2,
          ease: 'power2.out',
        },
        '<'
      )
      .to(
        '.about-us-section-{{ section.id }} .con1-content-front',
        {
          autoAlpha: 0,
          duration: 1.5,
        },
        '< 0.1'
      )
      .add(() => {
        const video = document.querySelector('.about-us-section-{{ section.id }} .con2-video video');
        if (video) video.play().catch(() => {});
      }, '< ')
      .to('.about-us-section-{{ section.id }} .con2-video', {
        autoAlpha: 0,
        duration: 2.5,
      })
      .to('.about-us-section-{{ section.id }} .con3-video-thumbnail', {
        autoAlpha: 1,
        duration: 1,
      })
      .add(() => {
        const video = document.querySelector('.about-us-section-{{ section.id }} .con4-play-btn video');
        if (video) video.play().catch(() => {});
      }, '< ')
      .to('.about-us-section-{{ section.id }} .con4-video-thumbnail', {
        autoAlpha: 1,
        duration: 1,
      })
      .to('.about-us-section-{{ section.id }} .con3-left--wrapper', {
        autoAlpha: 1,
        duration: 1,
      })
      .to(
        '.about-us-section-{{ section.id }}-cache-area',
        {
          y: -30,
          duration: 0.8,
          ease: 'power1.out',
          clearProps: 'y',
        },
        '< 0.3'
      );
  
      
  
    });
</script>
