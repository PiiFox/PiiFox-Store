<div class="about-us-section-{{ section.id }}">
  <div class="about-us-section--wrapper wow bounceInUp">
    <h2 class="about-us-section-title custom-txt-bold appear-delay{% cycle '','-1','-2','-3','-4' %}">
      {{ section.settings.about_us_title }}
    </h2>
    <div class="about-us-section-content">
      {% assign about_us_video = section.blocks | where: 'type', 'con1_video' | first %}
      {% assign about_us_content = section.blocks | where: 'type', 'con2_Content' | first %}
      {% assign con3_video = section.blocks | where: 'type', 'con3_video' | first %}
      {% assign con4_video = section.blocks | where: 'type', 'con4_video' | first %}
      {% assign con4_content = section.blocks | where: 'type', 'con4_content' | first %}

      {% assign fallback_youtube = 'https://youtu.be/0XAb1Cx1-YA' %}
      {% assign about_us_thumbnail_url = about_us_video.settings.video.preview_image
        | default: about_us_video.settings.video_thumbnail
      %}

      {% if template.name == 'mobile' or request.device_type == 'mobile' %}
        {% assign video_sources = about_us_video.settings.video_m.sources | first | map: 'url' %}
      {% else %}
        {% assign video_sources = about_us_video.settings.video.sources | first | map: 'url' %}
      {% endif %}
      {% assign about_us_video_url = video_sources | default: fallback_youtube %}

      {% if about_us_content %}
        <div class="con1-content-front">
          <div class="con1-sub-title custom-txt-semibold">
            {{ about_us_content.settings.subtitle }}
          </div>
          <div class="con1-context custom-txt-regular">
            {% if about_us_content.settings.logo %}
              {% assign about_us_content_logo = about_us_content.settings.logo %}
            {% else %}
              {% assign about_us_content_logo = shop.brand.logo %}
            {% endif %}
            <img
              src="{{ about_us_content_logo | image_url: width:200, format: 'webp' }}"
              width="200"
              height="auto"
              alt="{{ about_us_content_logo.alt }}"
              loading="lazy"
              class="con1-logo"
            >
            {% if about_us_content.settings.context != blank %}
              <span>{{ about_us_content.settings.context }}</span>
            {% endif %}
          </div>
        </div>
        <div class="con1-content">
          <div class="con1-title custom-txt-extrabold">
            {{ about_us_content.settings.title }}
          </div>
        </div>
      {% endif %}

      <div
        class="con2-video"
        data-section-id="con2-video"
        data-section-type="video-section"
      >
        <video
          width="100%"
          height="100%"
          muted
          autoplay
          loop
          playsinline
          preload="metadata"
          poster="{{ about_us_thumbnail_url | image_url }}"
        >
          <source src="{{ about_us_video_url }}" type="application/x-mpegURL">
          <img
            width="1920"
            height="auto"
            src="{{ about_us_thumbnail_url | image_url: width:1920, format: 'webp' }}"
            srcset="
              {{ about_us_thumbnail_url | image_url: width:680, format: 'webp' }} 680w,
              {{ about_us_thumbnail_url | image_url: width:1920, format: 'webp' }} 1920w
            "
            sizes="(max-width: 768px) 680px, 1920px"
            alt="{{ about_us_video.settings.video_thumbnail.alt }}"
            loading="lazy"
            class="con2-video-thumbnail"
          >
        </video>
      </div>

      <div class="con3-video">
        {% if con3_video.settings.video %}
          {% assign con3_video_url = con3_video.settings.video.sources | first | map: 'url' %}
          <video
            width="100%"
            height="auto"
            muted
            autoplay
            loop
            playsinline
            preload="metadata"
            poster="{{ con3_video.settings.video_thumbnail | image_url }}"
          >
            <source src="{{ con3_video_url }}" type="application/x-mpegURL">
            <img
              width="1920"
              height="auto"
              src="{{ con3_video.settings.video_thumbnail | image_url: width:1920, format: 'webp' }}"
              alt="{{ con3_video.settings.video_thumbnail.alt }}"
              loading="lazy"
              class="con3-video-thumbnail"
            >
          </video>
        {% else %}
          <div class="con3-video-thumbnail"></div>
        {% endif %}
        <div class="con3--wrapper ">
          <div class="page-width">
            
            <div class="con3-left--wrapper">
              <div class="con4-context custom-txt-semibold">{{ con4_video.settings.context }}</div>
              <div
                class="con4-play-btn"
                data-section-id="con4-play-btn"
                data-section-type="video-section"
              >
                <video
                  width="100%"
                  height="100%"
                  muted
                  autoplay
                  loop
                  playsinline
                  preload="metadata"
                  poster="{{ about_us_thumbnail_url | image_url }}"
                >
                  <source src="{{ about_us_video_url }}" type="application/x-mpegURL">
                  <img
                    width="1920"
                    height="auto"
                    src="{{ about_us_thumbnail_url | image_url: width:1920, format: 'webp' }}"
                    srcset="
                      {{ about_us_thumbnail_url | image_url: width:680, format: 'webp' }} 680w,
                      {{ about_us_thumbnail_url | image_url: width:1920, format: 'webp' }} 1920w
                    "
                    sizes="(max-width: 768px) 680px, 1920px"
                    alt="{{ about_us_video.settings.video_thumbnail.alt }}"
                    loading="lazy"
                    class="con2-video-thumbnail"
                  >
                </video>
                <div class="con4-play-btn--wrapper">
                  <span class="custom-txt-semibold">{{ con4_video.settings.btn_label }}</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
