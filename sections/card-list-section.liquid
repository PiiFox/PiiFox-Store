<div class="card-list-section-{{ section.id }}">
  <div class="card-list-section--wrapper page-width wow bounceInUp">
    <h2 class="card-list-section-title custom-txt-bold appear-delay{% cycle '','-1','-2','-3','-4' %}">
      {{ section.settings.card_list_title }}
    </h2>
    <div class="card-list-section-description appear-delay{% cycle '','-1','-2','-3','-4' %}">
      {{ section.settings.card_list_description }}
    </div>
    <div class="card-list-section-content swiper-container">
      <div class="swiper-wrapper">
        {% for block in section.blocks %} 
          {% style %}
            .card-list-section-{{ section.id }} .swiper-container .swiper-slide-{{ block.id }} .card-list-section-card {
              background: url('{{ block.settings.card_bg | image_url }}') center / 100% 100% no-repeat;
            }
            .card-list-section-{{ section.id }} .swiper-slide-{{ block.id }} .card-list-section-card {
              color: {{ block.settings.card_text_color }};
            }
          {% endstyle %}
          {% case block.type %}
            {% when 'product_item' %}
              {% assign product = block.settings.product %}
              <a href="{{ product.url }}" class="swiper-slide swiper-slide-{{ block.id }}">
                <div class="card-list-section-card">
                  {% if block.settings.card_tag != blank %}
                    <div class="card-list-section-card-tag custom-txt-bold">{{ block.settings.card_tag }}</div>
                  {% endif %}
                  {% if product and product.featured_image %}
                  <img
                    src="{% if block.settings.card_img != blank %}{{ block.settings.card_img | image_url }}{% else %}{{ product.featured_image | image_url }}{% endif %}"
                    alt="{% if block.settings.card_title != blank %}{{ block.settings.card_title }}{% else %}{{ product.title }}{% endif %}"
                    width="100%"
                    height="auto"
                    loading="lazy"
                  >
                  {% else %}
                    {%- capture current -%}{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
                    {{ 'product-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                  <div class="card-list-section-card-content">
                    <h3 class="card-list-section-card-title custom-txt-semibold">
                      {% if block.settings.card_title != blank -%}
                        {{- block.settings.card_title -}}
                      {%- else -%}
                        {{- product.title -}}
                      {%- endif %}
                    </h3>
                    <div class="card-list-section-card-description">
                      {% if block.settings.card_description != blank -%}
                        {{- block.settings.card_description -}}
                      {%- else -%}
                        {{- product.metafields.custom.short_instruction -}}
                      {%- endif %}
                    </div>
                    <div class="card-list-section-option">
                      <div class="card-list-section-price custom-txt-bold">
                        {% liquid
                          assign on_sale = false
                          if product.compare_at_price > product.price
                            assign on_sale = true
                          endif
                        %}
                        {%- if on_sale -%}
                          <span class="visually-hidden">{{ 'products.general.regular_price' | t }}</span>
                          <span class="grid-product__price--original">{{ product.compare_at_price | money }}</span>
                          <span class="visually-hidden">{{ 'products.general.sale_price' | t }}</span>
                        {%- endif -%}
                        {%- if product.price_varies -%}
                          {%- assign price = product.price_min | money -%}
                          {{ 'products.general.from_text_html' | t: price: price }}
                        {%- else -%}
                          {{ product.price | money }}
                        {%- endif -%}
                        {%- if on_sale -%}
                          {%- if settings.product_save_amount -%}
                            {%- if settings.product_save_type == 'dollar' -%}
                              {%- capture saved_amount -%}{{ product.compare_at_price | minus: product.price | money }}{%- endcapture -%}
                            {%- else -%}
                              {%- capture saved_amount -%}{{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}%{%- endcapture -%}
                            {%- endif -%}
                            <span class="grid-product__price--savings custom-txt--regular">
                              {{ 'products.general.save_html' | t: saved_amount: saved_amount }}
                            </span>
                          {%- endif -%}
                        {%- endif -%}
                      </div>
                      <button class="card-list-section-card-btn">
                        {% if section.settings.btn_left_icon != blank %}
                          <img
                            src="{{ section.settings.btn_left_icon | image_url }}"
                            alt="{{ block.settings.card_title }}"
                            width="24"
                            height="24"
                            loading="lazy"
                          >
                        {% endif %}
                        {{ section.settings.product_btn_label }}
                        {% if section.settings.btn_right_icon != blank %}
                          <img
                            src="{{ section.settings.btn_right_icon | image_url }}"
                            alt="{{ block.settings.card_title }}"
                            width="24"
                            height="24"
                            loading="lazy"
                          >
                        {% endif %}
                      </button>
                    </div>
                  </div>
                </div>
              </a>
            {% when 'collection_item' %}
              {% assign collection = block.settings.collection %}
              <a href="{{ collection.url }}" class="swiper-slide swiper-slide-{{ block.id }}">
                <div class="card-list-section-card">
                  {% if block.settings.card_tag != blank %}
                    <div class="card-list-section-card-tag custom-txt-bold">{{ block.settings.card_tag }}</div>
                  {% endif %}
                  {% if collection and collection.featured_image %}
                    <img
                      src="{% if block.settings.card_img != blank %}{{ block.settings.card_img | image_url }}{% else %}{{ collection.featured_image | image_url }}{% endif %}"
                      alt="{% if block.settings.card_title != blank %}{{ block.settings.card_title }}{% else %}{{ collection.title }}{% endif %}"
                      width="100%"
                      height="auto"
                      loading="lazy"
                    >
                  {% else %}
                    {%- capture current -%}{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
                    {{ 'collection-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                  <div class="card-list-section-card-content">
                    <h3 class="card-list-section-card-title custom-txt-semibold">
                      {% if block.settings.card_title != blank -%}
                        {{- block.settings.card_title -}}
                      {%- else -%}
                        {{- collection.title -}}
                      {%- endif %}
                    </h3>
                    <div class="card-list-section-card-description">
                      {% if block.settings.card_description != blank -%}
                        {{- block.settings.card_description -}}
                      {%- else -%}
                        {{- collection.metafields.custom.banner_describe -}}
                      {%- endif %}
                    </div>
                    <button class="card-list-section-card-btn">
                      {% if section.settings.btn_left_icon != blank %}
                        <img
                          src="{{ section.settings.btn_left_icon | image_url }}"
                          alt="{{ block.settings.card_title }}"
                          width="24"
                          height="24"
                          loading="lazy"
                        >
                      {% endif %}
                      {{ section.settings.collection_btn_label }}
                      {% if section.settings.btn_right_icon != blank %}
                        <img
                          src="{{ section.settings.btn_right_icon | image_url }}"
                          alt="{{ block.settings.card_title }}"
                          width="24"
                          height="24"
                          loading="lazy"
                        >
                      {% endif %}
                    </button>
                  </div>
                </div>
              </a>
          {% endcase %}
        {% endfor %}
      </div>
      <div class="swiper-button-prev">
        <svg
          class="group-hover/svg:scale-[1.3] transition-scale duration-300 "
          xmlns="http://www.w3.org/2000/svg"
          xmlns:xlink="http://www.w3.org/1999/xlink"
          fill="none"
          version="1.1"
          width="24"
          height="24"
          viewBox="0 0 24 24"
        >
          <g><g transform="matrix(-1,0,0,1,30.833984375,0)"><path d="M15.4169921875,6.166748046875C15.4169921875,6.564568046875,15.5750271875,6.9461080468750005,15.8563321875,7.227408046875L20.6290021875,12.000078046875L15.8563321875,16.772748046875C15.5750271875,17.054048046875,15.4169921875,17.435548046875,15.4169921875,17.833448046875C15.4169921875,18.661848046875,16.0885651875,19.333448046875,16.9169921875,19.333448046875C17.3148121875,19.333448046875,17.6963521875,19.175348046875,17.9776521875,18.894048046875L23.810982187500002,13.060738046875C24.0922921875,12.779438046875,24.2503221875,12.397908046875,24.2503221875,12.000078046875C24.2503221875,11.602258046875,24.0922921875,11.220728046875,23.810982187500002,10.939418046875L17.9776521875,5.106088046875C17.6963521875,4.824783046875,17.3148121875,4.666748046875,16.9169921875,4.666748046875C16.0885651875,4.666748046875,15.4169921875,5.338321046875,15.4169921875,6.166748046875Z" fill-rule="evenodd" fill="#FFFFFF" fill-opacity="1"></path></g></g>
        </svg>
      </div>
      <div class="swiper-button-next">
        <svg
          class="group-hover/svg:scale-[1.3] transition-scale duration-300"
          xmlns="http://www.w3.org/2000/svg"
          xmlns:xlink="http://www.w3.org/1999/xlink"
          fill="none"
          version="1.1"
          width="24"
          height="24"
          viewBox="0 0 24 24"
        >
          <g><g><path d="M8.5830078125,6.166748046875C8.5830078125,6.564568046875,8.7410428125,6.9461080468750005,9.0223478125,7.227408046875L13.7950178125,12.000078046875L9.0223478125,16.772748046875C8.7410428125,17.054048046875,8.5830078125,17.435548046875,8.5830078125,17.833448046875C8.5830078125,18.661848046875,9.2545808125,19.333448046875,10.0830078125,19.333448046875C10.4808278125,19.333448046875,10.8623678125,19.175348046875,11.1436678125,18.894048046875L16.976997812500002,13.060738046875C17.2583078125,12.779438046875,17.4163378125,12.397908046875,17.4163378125,12.000078046875C17.4163378125,11.602258046875,17.2583078125,11.220728046875,16.976997812500002,10.939418046875L11.1436678125,5.106088046875C10.8623678125,4.824783046875,10.4808278125,4.666748046875,10.0830078125,4.666748046875C9.2545808125,4.666748046875,8.5830078125,5.338321046875,8.5830078125,6.166748046875Z" fill-rule="evenodd" fill="#FFFFFF" fill-opacity="1"></path></g></g>
        </svg>
      </div>
    </div>
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const cardListSwiper = new Swiper('.card-list-section-{{ section.id }} .swiper-container', {
      loop: true,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
      },
      navigation: {
        nextEl: `.card-list-section-{{section.id}} .swiper-button-next`,
        prevEl: `.card-list-section-{{section.id}} .swiper-button-prev`,
        enabled: {% if section.blocks.size > 1 %} true {% else %} false {% endif %}, 
      },
      breakpoints: {
        0: {
          slidesPerView: 1.5,
          spaceBetween: 10,
        },
        768: {
          slidesPerView: 2,
          spaceBetween: 20,
        },
        1440: {
          slidesPerView: 3,
          spaceBetween: 30,
        },
        2560: {
          slidesPerView: 4,
          spaceBetween: 30,
        }
      },
    });
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        cardListSwiper.update();
      }, 500);
    });
  });
</script>
{% style %}
  .card-list-section-{{ section.id }} {
      background-color: #fafafa;
      padding: 4em 0;
  }
  .card-list-section-{{ section.id }} .card-list-section--wrapper {
      text-align: left;
  }
  .card-list-section-{{ section.id }} .card-list-section--wrapper .card-list-section-title {
      font-size: 2.4em;
      font-weight: bold;
      padding-bottom: 0.5em;
      position: relative;
  }
  .card-list-section-{{ section.id }} .card-list-section--wrapper .card-list-section-title::before {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 2em;
      height: 0.2em;
      background: var(--colorThemePrimary);
      border-radius: 1em;
  }
  .card-list-section-{{ section.id }} .card-list-section--wrapper .card-list-section-title::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 2.5em;
      width: 0.4em;
      height: 0.2em;
      background: var(--colorThemePrimary);
      opacity: 0.5;
      border-radius: 1em;
  }
  .card-list-section-{{ section.id }} .card-list-section--wrapper .card-list-section-description {
      font-size: 1.6em;
      margin-bottom: 2em;
      color: #95979b;
  }
  .card-list-section-{{ section.id }} .card-list-section--wrapper .card-list-section-content {
      width: 100%;
      margin: 0 auto;
      overflow: hidden;
      position: relative;
  }
  .card-list-section-{{ section.id }} .swiper-container {
      height: 100%;
      position: relative;
  }
  .card-list-section-{{ section.id }} .swiper-wrapper{
      height: 100%;
      position: relative;
      align-items: stretch;
  }
  .card-list-section-{{ section.id }} .card-list-section--wrapper .swiper-slide {
      height: 100%;
      display: flex;
  }
  .card-list-section-{{ section.id }} .card-list-section-card {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      padding: 2em;
      border-radius: 1em;
      box-shadow: 0 0 1px rgba(0, 0, 0, 0.3);
      position: relative;
  }
  .card-list-section-{{ section.id }} .card-list-section-card-content {
      width: 100%;
      height: 12em;
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: space-between;
  }
  .card-list-section-{{ section.id }} .card-list-section-card > img,
  .card-list-section-{{ section.id }} .card-list-section-card > svg {
      width: 90%;
      height: auto;
      aspect-ratio: 1/1;
      object-fit: contain;
      padding: 1em;
      margin: 0 auto;
  }
  .card-list-section-{{ section.id }} .card-list-section-card .card-list-section-card-tag {
      border-radius: 1em;
      border: 1px solid currentColor;
      padding: 0 1em;
      position: absolute;
      top: 1em;
      left: 1em;
  }
  .card-list-section-{{ section.id }} .card-list-section-card-title {
      font-size: 1.6em;
      margin-bottom: 0.5em;
      display: -webkit-box;
      -webkit-line-clamp: 1;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
      word-break: break-word;
  }
  .card-list-section-{{ section.id }} .card-list-section-card-description {
      font-size: 1.1em;
      line-height: 1.2em;
      height: 2.4em;
      margin-bottom: 1em;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
      word-break: break-word;
      position: relative;
  }

  .card-list-section-{{ section.id }} .card-list-section-option {
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 0.5em;
      position: relative;
  }
  .card-list-section-{{ section.id }} .card-list-section-option::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 5em;
      height: 0px;
      border-top: 2px solid var(--colorThemePrimary);
  }
  .card-list-section-{{ section.id }} .card-list-section-price {
      font-size: 1.6em;
      font-weight: bold;
      color: var(--colorThemePrimary);
  }
  .card-list-section-{{ section.id }} .card-list-section-price .grid-product__price--savings {
      font-size: 1.1em;
      color: #95979b;
  }
  .card-list-section-{{ section.id }} .card-list-section-card-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0.6em 1em;
      background: var(--colorThemePrimary);
      color: #fff;
      border-radius: 20em;
      font-size: 0.8em;
      white-space: nowrap;
  }
  .card-list-section-{{ section.id }} .card-list-section-card-btn img:first-child {
      width: 1em;
      height: 1em;
      margin-right: 0.5em;
  }
  .card-list-section-{{ section.id }} .card-list-section-card-btn img:last-child {
      width: 1em;
      height: 1em;
      margin-left: 0.5em;
  }
  /* 初始状态：所有 Swiper 容器隐藏，避免出现未格式化布局 */
  .card-list-section-{{ section.id }} .swiper-container {
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  /* Swiper 初始化完成后显示 */
  .card-list-section-{{ section.id }} .swiper-container.swiper-initialized {
    visibility: visible;
    opacity: 1;
  }

  .card-list-section-{{ section.id }} .swiper-container .swiper-button-next,
  .card-list-section-{{ section.id }} .swiper-container .swiper-button-prev {
    font-size: 1.2em;
    width: 2.5em;
    height: 2.5em;
    display: inline-flex;
    place-items: center;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.5);
  }
  .card-list-section-{{ section.id }} .swiper-container .swiper-button-next[aria-disabled="true"],
  .card-list-section-{{ section.id }} .swiper-container .swiper-button-prev[aria-disabled="true"] {
    opacity: 0;
    transition: opacity 0.3s ease;
    visibility: hidden;
  }
  @media screen and (max-width: 768px) {
      .card-list-section-{{ section.id }} {
          font-size: 0.9em;
      }
  }
{% endstyle %}

