    "1659777980925175b6": {
      "type": "sticky-faq",
      "blocks": {
        "16597779801a74dd1f-0": {
          "type": "question",
          "settings": {
            "title": "Q: Do you ship overseas?",
            "text": "<p>A: Yes, for volume Purchase, we ship all over the world. Shipping costs will apply, and will be added at checkout. For small quantities purchase, free shipping to the USA so far. We run discounts and promotions all year, so stay tuned for exclusive deals.</p>",
            "category": "shipping"
          }
        },
        "16597779801a74dd1f-1": {
          "type": "question",
          "settings": {
            "title": "Q: How long will it take to get my order?",
            "text": "<p>A: Normally orders processed here will take 5-7 business days to arrive if you're in USA. Overseas deliveries will take longer depending on where you are. Delivery details will be provided in your confirmation email.</p>",
            "category": "shipping"
          }
        },
        "16597779801a74dd1f-2": {
          "type": "question",
          "settings": {
            "title": "Q: Can I change or return my item?",
            "text": "<p>A: 1.If you want to return the units, please contact us at email 3epowers@gmail.com<br/>2.As part of our merchandise return process, we will need some info to process your return and replacement:<br/>Order number:<br/>Shipping address:S/N code(on the bottom of the battery):<br/>Please attached the pictures to show the item situation.<br/>You are always entitled to an exchange or refund within 30 days after you have received your package, as long as the item has not been used. All original packaging, price labels etc. shall be returned together with the product without having been tampered with. Please note that you are responsible for the product until it reaches us. Thank you in advance.</p>",
            "category": "shipping"
          }
        },
        "16597779801a74dd1f-3": {
          "type": "question",
          "settings": {
            "title": "Q: Any Expedited Shipping? I need it ASAP.",
            "text": "<p>A: We will try our best to ship your order as soon as possible. Please feel free to contact us via 3epowers@gmail.com for more details.</p>",
            "category": "shipping"
          }
        },
        "b6a1bc9f-353f-44e0-88e0-4c4487ab219e": {
          "type": "question",
          "settings": {
            "title": "Q: What payment methods do you offer?",
            "text": "<p>A: We accept the Paypal so far.<br/>The amount will be deducted from your account when the purchased item(s) leaves our stock.</p>",
            "category": "Payment"
          }
        },
        "5c0d7afe-5cfd-41cc-9a2e-8482846da760": {
          "type": "question",
          "settings": {
            "title": "Q: Can I use P15 to charge my devices while it is charged through the car port?",
            "text": "<p>A: P15 can be recharged through your car port and power your devices simultaneously.</p>",
            "category": "Product"
          }
        },
        "0e75c58a-602c-459a-8aa3-5fd72b28f931": {
          "type": "question",
          "settings": {
            "title": "Q: Does 3EPOWERS portable power station support charging and discharge simultaneously?",
            "text": "<p>A: Sure. However, in order to better protect the cycle life of the battery, it is not recommended to charge and discharge the battery at the same time.</p>",
            "category": "Product"
          }
        },
        "6d3749c9-fea7-427d-bdc8-ac0585eab67d": {
          "type": "question",
          "settings": {
            "title": "Q: I have a specific questions for some product, where do I find information?",
            "text": "<p>A: We have the specifications and FAQs for each product, where you can find out the information there. If you still can’t find the answer, you can email us at 3epowers@gamil.com.</p>",
            "category": "Product"
          }
        },
        "d520ab99-de6d-46c4-be32-aaa8dc867090": {
          "type": "question",
          "settings": {
            "title": "Q: Is 3EPOWERS solar panel waterproof?",
            "text": "<p>A: Pls do not expose it to constant rain or snow. Tips: The charging time are affected by many factors: such as the light intensity and the panel's angle put on the ground.</p>",
            "category": "Product"
          }
        },
        "91a234c7-6c3a-4ca0-8485-9318c576bb76": {
          "type": "question",
          "settings": {
            "title": "Q: Can I use the 3EPOWERS solar panel to charge the third party power station, such as PV200?",
            "text": "<p>A: 1. The third-party power station should support solar charging</p><p>2. The OCV of the PV200 is about 26.1V</p><p>3. If the cable connector is MC4 connector.</p><p>If you any more questions, please reach out to us via 3epowers@gmail.com. We will get back to you within 24 hours on business days and we'll be more than happy to help.</p>",
            "category": "Product"
          }
        }
      },
